---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";
import Note from "../components/garden/Note.astro";

import { getNotes } from "../sanity/lib/documents/notes";
const notes = await getNotes();

const allTags = [...new Set(notes.flatMap((n: any) => n.tags || []))].sort();
const maturityLevels = [...new Set(notes.map((n: any) => n.maturity).filter(Boolean))];
const maturityConfig: Record<string, { emoji: string; label: string }> = {
  seedling:  { emoji: '🌱', label: 'Seedling' },
  budding:   { emoji: '🌿', label: 'Budding' },
  evergreen: { emoji: '🌲', label: 'Evergreen' },
};
---

<PrimaryLayout page_title="garden">
  <main class="page-main">
    <div class="garden-container">

      <PageHeader
        heading="garden"
        subheading="notes, artifacts, and other musings"
        content="unrefined artifacts and snippets of varying levels of maturity"
      />

      <div class="garden-layout">

        <!-- Sidebar -->
        <aside class="garden-sidebar">
          <div class="sidebar-panel">
            <h3 class="sidebar-label">Filter by Tag</h3>
            {allTags.length > 0 ? (
              <div class="sidebar-btns">
                <button class="sidebar-btn btn-active tag-filter-btn" data-tag="all">All Notes</button>
                {(allTags as any[]).map((tag) => (
                  <button class="sidebar-btn tag-filter-btn" data-tag={tag}>#{tag}</button>
                ))}
              </div>
            ) : (
              <p class="sidebar-empty">No tags yet</p>
            )}
          </div>
        </aside>

        <!-- Notes -->
        <div class="garden-notes">
          {maturityLevels.length > 0 && (
            <div class="filter-row">
              <button class="filter-pill pill-active maturity-filter-pill" data-maturity="all">All Maturity</button>
              {(maturityLevels as any[]).map((level) => {
                const cfg = maturityConfig[level as string];
                return cfg && (
                  <button class="filter-pill maturity-filter-pill" data-maturity={level}>
                    {cfg.emoji} {cfg.label}
                  </button>
                );
              })}
            </div>
          )}

          {notes.length > 0 ? (
            <div class="notes-grid" id="notes-grid">
              {(notes as any[]).map((note) => (
                <div
                  class="note-item"
                  data-tags={JSON.stringify(note.tags || [])}
                  data-maturity={note.maturity || ''}
                >
                  <Note
                    title={note.title}
                    date={note.date}
                    excerpt={note.excerpt}
                    slug={note.slug}
                    tags={note.tags || []}
                    maturity={note.maturity}
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="notes-empty">
              <p>No notes planted yet... 🌱</p>
            </div>
          )}
        </div>

      </div>
    </div>
  </main>
</PrimaryLayout>

<script>
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
  const maturityBtns = document.querySelectorAll<HTMLButtonElement>('.maturity-filter-pill');
  const noteItems = document.querySelectorAll<HTMLElement>('.note-item');

  let selectedTag = 'all';
  let selectedMaturity = 'all';

  function filterNotes() {
    noteItems.forEach(item => {
      const tags = JSON.parse(item.dataset.tags || '[]') as string[];
      const maturity = item.dataset.maturity || '';
      const tagMatch = selectedTag === 'all' || tags.includes(selectedTag);
      const maturityMatch = selectedMaturity === 'all' || maturity === selectedMaturity;
      item.style.display = (tagMatch && maturityMatch) ? '' : 'none';
    });
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedTag = btn.dataset.tag || 'all';
      tagBtns.forEach(b => b.classList.remove('btn-active'));
      btn.classList.add('btn-active');
      filterNotes();
    });
  });

  const initialTag = new URLSearchParams(window.location.search).get('tag');
  if (initialTag) {
    const match = [...tagBtns].find(btn => btn.dataset.tag === initialTag);
    if (match) {
      selectedTag = initialTag;
      tagBtns.forEach(b => b.classList.remove('btn-active'));
      match.classList.add('btn-active');
      filterNotes();
      match.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  maturityBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedMaturity = btn.dataset.maturity || 'all';
      maturityBtns.forEach(b => b.classList.remove('pill-active'));
      btn.classList.add('pill-active');
      filterNotes();
    });
  });
</script>

<style>
  .garden-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .garden-layout {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  /* Sidebar */
  .garden-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 100px;
  }

  .sidebar-panel {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
  }

  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dimmer);
    margin-bottom: 14px;
  }

  .sidebar-btns {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-empty {
    font-size: 0.8rem;
    color: var(--dimmer);
    font-style: italic;
  }

  /* Notes area */
  .garden-notes {
    flex: 1;
    min-width: 0;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .notes-empty {
    padding: 80px 0;
    color: var(--dimmer);
    font-size: 0.9rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .garden-layout { flex-direction: column; }
    .garden-sidebar { width: 100%; position: static; }
    .sidebar-btns { flex-direction: row; flex-wrap: wrap; gap: 4px; }
    .sidebar-btn { width: auto !important; }
  }

  @media (max-width: 640px) {
    .garden-container { padding: 32px 20px 64px; }
    .notes-grid { grid-template-columns: 1fr; }
  }
</style>
