---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";
import Book from "../components/books/Book.astro";
import Album from "../components/albums/Album.astro";

import { getBooks } from "../sanity/lib/documents/books";
const books = await getBooks();

const years = [...new Set(books.map((b: any) => b.yearRead).filter(Boolean))].sort((a: any, b: any) => b - a);
const currentYear = new Date().getFullYear();
const hasCurrentYearBooks = years.includes(currentYear);
const defaultBookYear = hasCurrentYearBooks ? currentYear : 'all';

import { getAlbums } from "../sanity/lib/documents/music";
const albums = await getAlbums();

const albumYears = [...new Set(albums.map((a: any) => a.yearListened).filter(Boolean))].sort((a: any, b: any) => b - a);
const hasCurrentYearAlbums = albumYears.includes(currentYear);
const defaultAlbumYear = hasCurrentYearAlbums ? currentYear : 'all';
---

<PrimaryLayout page_title="media">
  <main class="page-main">
    <div class="media-container">

      <!-- Books -->
      <div class="media-section">
        <PageHeader
          heading="books"
          subheading="things i've been reading"
          content="books that I've completed recently."
        />

        {years.length > 0 && (
          <div class="filter-row">
            <button class="filter-pill pill-active year-filter-pill" data-year="all">All Years</button>
            {(years as any[]).map((year) => (
              <button
                class={`filter-pill year-filter-pill${year === defaultBookYear ? ' pill-active' : ''}`}
                data-year={year}
              >
                {year}
              </button>
            ))}
          </div>
        )}

        <div class="scroll-row" id="books-list">
          {(books as any[]).map((book) => (
            <div
              class="scroll-item book-item"
              data-year={book.yearRead || 'unknown'}
              style={defaultBookYear !== 'all' && book.yearRead !== defaultBookYear ? 'display:none' : ''}
            >
              <Book
                title={book.title}
                author={book.author}
                cover={book.cover}
                slug={book.slug}
                currentlyReading={book.currentlyReading}
              />
            </div>
          ))}
        </div>
      </div>

      <hr class="section-divider" />

      <!-- Albums -->
      <div class="media-section">
        <PageHeader
          heading="albums"
          subheading="things i've been listening to"
          content="albums that i've listened to lately."
        />

        {albumYears.length > 0 && (
          <div class="filter-row">
            <button class="filter-pill pill-active album-year-filter-pill" data-year="all">All Years</button>
            {(albumYears as any[]).map((year) => (
              <button
                class={`filter-pill album-year-filter-pill${year === defaultAlbumYear ? ' pill-active' : ''}`}
                data-year={year}
              >
                {year}
              </button>
            ))}
          </div>
        )}

        <div class="scroll-row">
          {(albums as any[]).map((album) => (
            <div
              class="scroll-item album-item"
              data-year={album.yearListened || 'unknown'}
              style={defaultAlbumYear !== 'all' && album.yearListened !== defaultAlbumYear ? 'display:none' : ''}
            >
              <Album
                title={album.title}
                artist={album.artist}
                cover={album.cover}
                color={album.color}
                slug={album.slug}
                currentlyListening={album.currentlyListening}
              />
            </div>
          ))}
        </div>
      </div>

    </div>
  </main>
</PrimaryLayout>

<script>
  // Book year filter
  const bookPills = document.querySelectorAll<HTMLButtonElement>('.year-filter-pill');
  const bookItems = document.querySelectorAll<HTMLElement>('.book-item');

  bookPills.forEach(pill => {
    pill.addEventListener('click', () => {
      const year = pill.dataset.year;
      bookPills.forEach(p => p.classList.remove('pill-active'));
      pill.classList.add('pill-active');
      bookItems.forEach(item => {
        item.style.display = (year === 'all' || item.dataset.year === year) ? '' : 'none';
      });
    });
  });

  // Album year filter
  const albumPills = document.querySelectorAll<HTMLButtonElement>('.album-year-filter-pill');
  const albumItems = document.querySelectorAll<HTMLElement>('.album-item');

  albumPills.forEach(pill => {
    pill.addEventListener('click', () => {
      const year = pill.dataset.year;
      albumPills.forEach(p => p.classList.remove('pill-active'));
      pill.classList.add('pill-active');
      albumItems.forEach(item => {
        item.style.display = (year === 'all' || item.dataset.year === year) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .media-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .media-section {
    margin-bottom: 16px;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .scroll-row {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    padding-bottom: 16px;
    scrollbar-width: none;
  }

  .scroll-row::-webkit-scrollbar { display: none; }

  .scroll-item {
    flex-shrink: 0;
    width: 220px;
  }

  @media (max-width: 640px) {
    .media-container { padding: 32px 20px 64px; }
    .scroll-item { width: 180px; }
  }
</style>
