---
import { client } from "../../sanity/lib/client";
import { getBookBySlug } from "../../sanity/lib/documents/books";
import { renderMarkdown } from "../../sanity/lib/portableText";
import PrimaryLayout from "../../layouts/primary_layout.astro";

export async function getStaticPaths() {
  const books = await client.fetch(`*[_type == "book" && defined(slug.current)]{ "slug": slug.current }`);
  return (books || []).map((b: any) => ({ params: { slug: b.slug } }));
}

const { slug } = Astro.params;
const book = await getBookBySlug(slug);
const content = renderMarkdown(book.content);
---

<PrimaryLayout page_title={book.title}>
  <main class="page-main">
    <div class="book-detail-container">

      <a href="/media" class="back-link">← Back to Media</a>

      <div class="book-detail-layout">

        <!-- Cover + meta -->
        <div class="book-detail-sidebar">
          {book.currentlyReading && (
            <div class="reading-badge">Currently Reading</div>
          )}
          <div class="book mx-auto">
            <div class="book-cover" style={{ backgroundImage: `url(${book.cover})` }}>
              <div class="effect"></div>
              <div class="light"></div>
            </div>
            <div class="book-inside"></div>
          </div>
          <div class="book-detail-meta">
            <h1 class="book-detail-title">{book.title}</h1>
            <p class="book-detail-author">{book.author}</p>
            {book.yearRead && <p class="book-detail-year">Read in {book.yearRead}</p>}
            <div class="book-stars">
              <span class="star star--filled">★</span>
              <span class="star star--filled">★</span>
              <span class="star star--filled">★</span>
              <span class="star">☆</span>
              <span class="star">☆</span>
            </div>
          </div>
        </div>

        <!-- Review -->
        <div class="book-detail-review">
          {content ? (
            <>
              <h2 class="review-heading">My Review</h2>
              <div class="prose" set:html={content}></div>
            </>
          ) : (
            <p class="review-empty">No review yet.</p>
          )}
        </div>

      </div>
    </div>
  </main>
</PrimaryLayout>

<style>
  .book-detail-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px 32px 96px;
  }

  .book-detail-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    align-items: flex-start;
    margin-top: 16px;
  }

  .book-detail-sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    position: sticky;
    top: 100px;
  }

  .reading-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 14px;
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 99px;
  }

  .book-detail-meta {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .book-detail-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    line-height: 1.15;
  }

  .book-detail-author {
    font-size: 1rem;
    color: var(--dim);
    font-weight: 300;
  }

  .book-detail-year {
    font-size: 0.78rem;
    color: var(--dimmer);
    letter-spacing: 0.04em;
  }

  .book-stars {
    display: flex;
    justify-content: center;
    gap: 2px;
    font-size: 1.4rem;
    margin-top: 4px;
  }

  .star { color: var(--dimmer); }
  .star--filled { color: #fbbf24; }

  .book-detail-review {
    padding-top: 8px;
  }

  .review-heading {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .book-detail-container { padding: 24px 20px 64px; }
    .book-detail-layout { grid-template-columns: 1fr; }
    .book-detail-sidebar { position: static; }
  }
</style>
