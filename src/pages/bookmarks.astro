---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";

import { getBookmarks } from "../sanity/lib/documents/bookmarks";
const bookmarks = await getBookmarks();

const allCategories = [...new Set(bookmarks.map((b: any) => b.category).filter(Boolean))].sort();
const allTags = [...new Set(bookmarks.flatMap((b: any) => b.tags || []))].sort();

const categoryConfig: Record<string, { icon: string; label: string }> = {
  development:  { icon: '💻', label: 'Development'  },
  design:       { icon: '🎨', label: 'Design'       },
  productivity: { icon: '⚡', label: 'Productivity' },
  learning:     { icon: '📚', label: 'Learning'     },
  tools:        { icon: '🔧', label: 'Tools'        },
  reading:      { icon: '📖', label: 'Reading'      },
  inspiration:  { icon: '✨', label: 'Inspiration'  },
  other:        { icon: '📌', label: 'Other'        },
};
---

<PrimaryLayout page_title="bookmarks">
  <main class="page-main">
    <div class="bookmarks-container">

      <PageHeader
        heading="bookmarks"
        subheading="curated links and resources"
        content="a collection of sites, tools, and resources I find interesting"
      />

      <div class="bookmarks-layout">

        <!-- Sidebar -->
        <aside class="bookmarks-sidebar">

          <!-- Category filter -->
          <div class="sidebar-panel">
            <h3 class="sidebar-label">Category</h3>
            {allCategories.length > 0 ? (
              <div class="sidebar-btns">
                <button class="sidebar-btn btn-active category-filter-btn" data-category="all">All Bookmarks</button>
                {(allCategories as any[]).map((cat) => {
                  const cfg = categoryConfig[cat as string];
                  return (
                    <button class="sidebar-btn category-filter-btn" data-category={cat}>
                      {cfg && <span>{cfg.icon}</span>}
                      {cfg ? cfg.label : cat}
                    </button>
                  );
                })}
              </div>
            ) : (
              <p class="sidebar-empty">No categories yet</p>
            )}
          </div>

          <!-- Tag filter -->
          {allTags.length > 0 && (
            <div class="sidebar-panel">
              <h3 class="sidebar-label">Tags</h3>
              <div class="tag-chips">
                {(allTags as any[]).map((tag) => (
                  <button class="tag-chip tag-filter-btn" data-tag={tag}>#{tag}</button>
                ))}
              </div>
            </div>
          )}

        </aside>

        <!-- Grid -->
        <div class="bookmarks-grid-wrap">
          {bookmarks.length > 0 ? (
            <div class="bookmarks-grid" id="bookmarks-grid">
              {(bookmarks as any[]).map((bookmark) => {
                const cat = categoryConfig[bookmark.category as string];
                return (
                  <div class="bookmark-item" data-category={bookmark.category || ''} data-tags={JSON.stringify(bookmark.tags || [])}>
                    <a href={bookmark.url} target="_blank" rel="noopener noreferrer" class="bookmark-card">
                      {bookmark.thumbnail && (
                        <div class="bookmark-thumb">
                          <img src={bookmark.thumbnail} alt={bookmark.title} />
                        </div>
                      )}
                      <div class="bookmark-body">
                        {cat && (
                          <span class="bookmark-category">{cat.icon} {cat.label}</span>
                        )}
                        <h3 class="bookmark-title">{bookmark.title}</h3>
                        {bookmark.description && (
                          <p class="bookmark-desc">{bookmark.description}</p>
                        )}
                        <p class="bookmark-url">{bookmark.url}</p>
                        {bookmark.tags && bookmark.tags.length > 0 && (
                          <div class="bookmark-tags">
                            {(bookmark.tags as string[]).map((tag) => (
                              <span class="bookmark-tag">#{tag}</span>
                            ))}
                          </div>
                        )}
                      </div>
                    </a>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="bookmarks-empty">
              <p>No bookmarks yet... 📌</p>
            </div>
          )}
        </div>

      </div>
    </div>
  </main>
</PrimaryLayout>

<script>
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.category-filter-btn');
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.bookmark-item');

  let selectedCategory = 'all';
  const selectedTags = new Set<string>();

  function filter() {
    items.forEach(item => {
      const cat = item.dataset.category || '';
      const tags = JSON.parse(item.dataset.tags || '[]') as string[];
      const catMatch = selectedCategory === 'all' || cat === selectedCategory;
      const tagMatch = selectedTags.size === 0 || tags.some(t => selectedTags.has(t));
      item.style.display = (catMatch && tagMatch) ? '' : 'none';
    });
  }

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedCategory = btn.dataset.category || 'all';
      catBtns.forEach(b => b.classList.remove('btn-active'));
      btn.classList.add('btn-active');
      filter();
    });
  });

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag || '';
      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
        btn.classList.remove('chip-active');
      } else {
        selectedTags.add(tag);
        btn.classList.add('chip-active');
      }
      filter();
    });
  });
</script>

<style>
  .bookmarks-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .bookmarks-layout {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  /* Sidebar */
  .bookmarks-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sidebar-panel {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
  }

  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dimmer);
    margin-bottom: 14px;
  }

  .sidebar-btns {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-empty {
    font-size: 0.8rem;
    color: var(--dimmer);
    font-style: italic;
  }

  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag-chip {
    padding: 3px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--dim);
    background: var(--black-80);
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .tag-chip:hover { background: var(--black-70); color: var(--white); }
  .tag-chip.chip-active { background: var(--white); color: var(--black-100); border-color: var(--white); }

  /* Grid */
  .bookmarks-grid-wrap { flex: 1; min-width: 0; }

  .bookmarks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .bookmark-card {
    display: flex;
    flex-direction: column;
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color 0.2s, transform 0.2s;
  }

  .bookmark-card:hover {
    border-color: var(--dim);
    transform: translateY(-2px);
  }

  .bookmark-thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--black-80);
  }

  .bookmark-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
    transition: transform 0.4s, filter 0.4s;
  }

  .bookmark-card:hover .bookmark-thumb img {
    transform: scale(1.04);
    filter: grayscale(0);
  }

  .bookmark-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .bookmark-category {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--dimmer);
  }

  .bookmark-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.35;
  }

  .bookmark-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bookmark-url {
    font-size: 0.7rem;
    font-family: monospace;
    color: var(--dimmer);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bookmark-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }

  .bookmark-tag {
    font-size: 0.65rem;
    padding: 2px 6px;
    background: var(--black-80);
    color: var(--dimmer);
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .bookmarks-empty {
    padding: 80px 0;
    color: var(--dimmer);
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .bookmarks-layout { flex-direction: column; }
    .bookmarks-sidebar { width: 100%; position: static; }
    .sidebar-btns { flex-direction: row; flex-wrap: wrap; gap: 4px; }
    .sidebar-btn { width: auto !important; }
  }

  @media (max-width: 640px) {
    .bookmarks-container { padding: 32px 20px 64px; }
    .bookmarks-grid { grid-template-columns: 1fr; }
  }
</style>
