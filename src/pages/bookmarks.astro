---
import PrimaryLayout from "../layouts/primary_layout.astro";
import Navigation from "../components/shared/navigation.astro";
import PageHeader from "../components/shared/page_header.astro";

import { getBookmarks } from "../sanity/lib/documents/bookmarks";
const bookmarks = await getBookmarks();

// Extract all unique categories and tags from bookmarks
const allCategories = [...new Set(bookmarks.map((bookmark: any) => bookmark.category).filter(Boolean))].sort();
const allTags = [...new Set(bookmarks.flatMap((bookmark: any) => bookmark.tags || []))].sort();

const categoryConfig = {
  development: { icon: "💻", label: "Development" },
  design: { icon: "🎨", label: "Design" },
  productivity: { icon: "⚡", label: "Productivity" },
  learning: { icon: "📚", label: "Learning" },
  tools: { icon: "🔧", label: "Tools" },
  reading: { icon: "📖", label: "Reading" },
  inspiration: { icon: "✨", label: "Inspiration" },
  other: { icon: "📌", label: "Other" }
};
---
<PrimaryLayout page_title="bookmarks">
  <div class="overflow-hidden">
    <div class="relative">
      <div class="absolute inset-2 bottom-0 rounded-4xl ring-1 ring-black/5 ring-inset bg-linear-115 from-[#ffffff] from-28% via-[#F5F5F5] via-70% to-[#EBEBEB] sm:bg-linear-145"></div>
      <div class="relative px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:max-w-7xl">
          <Navigation />
        </div>
      </div>
    </div>
    <main>
      <div class="py-16">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:max-w-7xl">
            <div class="mb-12">
              <PageHeader heading="bookmarks" subheading="curated links and resources" content="a collection of sites, tools, and resources I find interesting"/>
            </div>

            <div class="flex flex-col lg:flex-row gap-8">
              <!-- Sidebar -->
              <aside class="lg:w-64 flex-shrink-0">
                <div class="sticky top-8 space-y-6">
                  <!-- Category Filter -->
                  <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-4 uppercase tracking-wide">Filter by Category</h3>

                    {allCategories.length > 0 ? (
                      <div class="space-y-2">
                        <button
                          class="category-filter-btn w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 transition-colors bg-gray-900 text-white"
                          data-category="all"
                        >
                          All Bookmarks
                        </button>
                        {allCategories.map((category: any) => {
                          const config = categoryConfig[category as keyof typeof categoryConfig];
                          return (
                            <button
                              class="category-filter-btn w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 transition-colors text-gray-700"
                              data-category={category}
                            >
                              {config && <span class="mr-2">{config.icon}</span>}
                              {config ? config.label : category}
                            </button>
                          );
                        })}
                      </div>
                    ) : (
                      <p class="text-sm text-gray-500 italic">No categories yet</p>
                    )}
                  </div>

                  <!-- Tag Filter -->
                  {allTags.length > 0 && (
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-6">
                      <h3 class="text-sm font-semibold text-gray-900 mb-4 uppercase tracking-wide">Filter by Tag</h3>
                      <div class="flex flex-wrap gap-2">
                        {allTags.map((tag: any) => (
                          <button
                            class="tag-filter-btn text-xs px-2 py-1 rounded border border-gray-300 hover:bg-gray-100 transition-colors text-gray-700"
                            data-tag={tag}
                          >
                            #{tag}
                          </button>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </aside>

              <!-- Bookmarks Grid -->
              <div class="flex-1">
                {bookmarks.length > 0 ? (
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="bookmarks-grid">
                    {bookmarks.map((bookmark: any) => {
                      const categoryData = categoryConfig[bookmark.category as keyof typeof categoryConfig];
                      return (
                        <div class="bookmark-card" data-category={bookmark.category || ''} data-tags={JSON.stringify(bookmark.tags || [])}>
                          <a href={bookmark.url} target="_blank" rel="noopener noreferrer" class="block group">
                            <div class="relative overflow-hidden rounded-lg bg-white border border-gray-200 shadow-sm transition-all hover:shadow-md h-full">
                              {/* Thumbnail */}
                              {bookmark.thumbnail && (
                                <div class="aspect-video overflow-hidden bg-gray-100">
                                  <img src={bookmark.thumbnail} alt={bookmark.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform" />
                                </div>
                              )}

                              <div class="p-4">
                                {/* Category Badge */}
                                {categoryData && (
                                  <div class="mb-2">
                                    <span class="inline-flex items-center px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded border border-gray-200">
                                      <span class="mr-1">{categoryData.icon}</span>
                                      {categoryData.label}
                                    </span>
                                  </div>
                                )}

                                {/* Title */}
                                <h3 class="text-lg font-semibold text-gray-950 mb-2 group-hover:text-blue-600 transition-colors">
                                  {bookmark.title}
                                </h3>

                                {/* Description */}
                                {bookmark.description && (
                                  <p class="text-sm text-gray-600 leading-relaxed mb-3 line-clamp-2">
                                    {bookmark.description}
                                  </p>
                                )}

                                {/* URL */}
                                <p class="text-xs text-gray-500 font-mono mb-3 truncate">
                                  {bookmark.url}
                                </p>

                                {/* Tags */}
                                {bookmark.tags && bookmark.tags.length > 0 && (
                                  <div class="flex flex-wrap gap-1">
                                    {bookmark.tags.map((tag: string) => (
                                      <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 border border-gray-200 rounded">
                                        #{tag}
                                      </span>
                                    ))}
                                  </div>
                                )}

                                {/* Featured indicator */}
                                {bookmark.featured && (
                                  <div class="absolute top-4 right-4">
                                    <span class="inline-flex items-center px-2 py-1 text-xs font-semibold bg-blue-500 text-white rounded-full shadow-lg">
                                      ⭐ Featured
                                    </span>
                                  </div>
                                )}
                              </div>
                            </div>
                          </a>
                        </div>
                      );
                    })}
                  </div>
                ) : (
                  <div class="text-center py-24">
                    <p class="text-gray-600 text-lg">No bookmarks yet... 📌</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</PrimaryLayout>

<script>
  const categoryFilterButtons = document.querySelectorAll('.category-filter-btn');
  const tagFilterButtons = document.querySelectorAll('.tag-filter-btn');
  const bookmarkCards = document.querySelectorAll('.bookmark-card');

  let selectedCategory = 'all';
  let selectedTags = new Set<string>();

  function filterBookmarks() {
    bookmarkCards.forEach(card => {
      const cardElement = card as HTMLElement;
      const bookmarkCategory = card.getAttribute('data-category') || '';
      const bookmarkTags = JSON.parse(card.getAttribute('data-tags') || '[]');

      const categoryMatch = selectedCategory === 'all' || bookmarkCategory === selectedCategory;
      const tagMatch = selectedTags.size === 0 || bookmarkTags.some((tag: string) => selectedTags.has(tag));

      if (categoryMatch && tagMatch) {
        cardElement.style.display = 'block';
      } else {
        cardElement.style.display = 'none';
      }
    });
  }

  // Category filtering
  categoryFilterButtons.forEach(button => {
    button.addEventListener('click', () => {
      selectedCategory = button.getAttribute('data-category') || 'all';

      // Update active button styling
      categoryFilterButtons.forEach(btn => {
        btn.classList.remove('bg-gray-900', 'text-white');
        btn.classList.add('text-gray-700');
      });
      button.classList.add('bg-gray-900', 'text-white');
      button.classList.remove('text-gray-700');

      filterBookmarks();
    });
  });

  // Tag filtering (multi-select)
  tagFilterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tag = button.getAttribute('data-tag');
      if (!tag) return;

      if (selectedTags.has(tag)) {
        selectedTags.delete(tag);
        button.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
        button.classList.add('text-gray-700', 'border-gray-300');
      } else {
        selectedTags.add(tag);
        button.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
        button.classList.remove('text-gray-700', 'border-gray-300');
      }

      filterBookmarks();
    });
  });
</script>
