---
import { client } from "../../sanity/lib/client";
import { renderMarkdown } from "../../sanity/lib/portableText";
import { getNoteBySlug } from "../../sanity/lib/documents/notes";
import PrimaryLayout from "../../layouts/primary_layout.astro";

export async function getStaticPaths() {
  const notes = await client.fetch(`*[_type == "note" && defined(slug.current)]{ "slug": slug.current }`);
  return (notes || []).map((note: any) => ({ params: { slug: note.slug } }));
}

const { slug } = Astro.params;
const note = await getNoteBySlug(slug);
const content = renderMarkdown(note.content);

const maturityConfig = {
  seedling:  { emoji: "🌱", label: "Seedling"  },
  budding:   { emoji: "🌿", label: "Budding"   },
  evergreen: { emoji: "🌲", label: "Evergreen" },
};
const maturity = maturityConfig[note.maturity as keyof typeof maturityConfig] || maturityConfig.seedling;
---

<PrimaryLayout page_title={note.title}>
  <main class="page-main">
    <div class="note-detail-container">

      <a href="/garden" class="back-link">← Back to Garden</a>

      <article class="note-paper-full">
        <div class="note-body">

          <div class="note-meta-row">
            {note.date && <span class="note-meta-date">{note.date}</span>}
            <span class="note-maturity-badge">{maturity.emoji} {maturity.label}</span>
          </div>

          <h1 class="note-detail-title">{note.title}</h1>

          {note.excerpt && (
            <p class="note-detail-excerpt">{note.excerpt}</p>
          )}

          <div class="note-prose" set:html={content}></div>

          {note.tags && note.tags.length > 0 && (
            <div class="note-tags-section">
              {(note.tags as string[]).map((tag) => (
                <a href={`/garden?tag=${tag}`} class="note-detail-tag">#{tag}</a>
              ))}
            </div>
          )}

          {note.relatedNotes && note.relatedNotes.length > 0 && (
            <div class="note-related">
              <h2 class="note-related-heading">Related Notes</h2>
              <div class="note-related-grid">
                {(note.relatedNotes as any[]).map((rel) => (
                  <a href={`/garden/${rel.slug}`} class="note-related-card">
                    <span class="note-related-title">{rel.title}</span>
                    {rel.excerpt && <span class="note-related-excerpt">{rel.excerpt}</span>}
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>
      </article>

    </div>
  </main>
</PrimaryLayout>

<style>
  .note-detail-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px 32px 96px;
  }

  /* ── Paper card — same visual as homepage .note-card ── */
  .note-paper-full {
    position: relative;
    overflow: hidden;
    border-radius: 2px;

    background-color: #E0E4EB;
    background-image: radial-gradient(circle, rgba(78, 87, 106, 0.12) 1px, transparent 1px);
    background-size: 14px 14px;

    box-shadow: 2px 4px 16px rgba(0, 0, 0, 0.5), 0 1px 3px rgba(0, 0, 0, 0.25);
  }

  /* Feed strip with sprocket holes */
  .note-paper-full::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 26px;
    background-color: #D1D6E0;
    background-image: radial-gradient(circle, #4E576A 4px, transparent 4.5px);
    background-size: 26px 28px;
    background-repeat: repeat-y;
    background-position: center 8px;
  }

  /* Red margin line */
  .note-paper-full::after {
    content: '';
    position: absolute;
    left: 26px; top: 0; bottom: 0;
    width: 1.5px;
    background: rgba(208, 58, 58, 0.5);
  }

  .note-body {
    position: relative;
    z-index: 1;
    padding: 48px 48px 56px 52px;
  }

  /* ── Header meta ── */
  .note-meta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .note-meta-date {
    font-size: 0.72rem;
    font-family: monospace;
    color: #667085;
  }

  .note-maturity-badge {
    font-size: 0.7rem;
    font-family: monospace;
    padding: 3px 10px;
    background: #D1D6E0;
    border: 1px solid rgba(78, 87, 106, 0.35);
    border-radius: 3px;
    color: #4E576A;
  }

  .note-detail-title {
    font-family: monospace;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: #0A0E15;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .note-detail-excerpt {
    font-size: 1rem;
    font-family: monospace;
    color: #373F4E;
    line-height: 1.65;
    margin-bottom: 32px;
    padding-bottom: 32px;
  }

  /* ── Prose ── */
  .note-prose {
    font-family: monospace;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #373F4E;
  }

  .note-prose :global(p) { margin-bottom: 1.1em; }

  .note-prose :global(h1),
  .note-prose :global(h2),
  .note-prose :global(h3),
  .note-prose :global(h4),
  .note-prose :global(h5),
  .note-prose :global(h6) {
    font-family: monospace;
    font-weight: 700;
    color: #0A0E15;
    line-height: 1.25;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }

  .note-prose :global(h1) { font-size: 1.5rem; }
  .note-prose :global(h2) {
    font-size: 1.2rem;
    padding-bottom: 0.3em;
    border-bottom: 1px dashed rgba(78, 87, 106, 0.35);
  }
  .note-prose :global(h3) { font-size: 1.05rem; }
  .note-prose :global(h4) { font-size: 0.95rem; }
  .note-prose :global(h5) { font-size: 0.9rem; opacity: 0.85; }
  .note-prose :global(h6) { font-size: 0.85rem; opacity: 0.75; }

  .note-prose :global(a) {
    color: #4E576A;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s;
  }
  .note-prose :global(a:hover) { opacity: 0.7; }

  .note-prose :global(strong) { color: #0A0E15; font-weight: 700; }
  .note-prose :global(em) { font-style: italic; }

  .note-prose :global(ul),
  .note-prose :global(ol) {
    padding-left: 1.6em;
    margin-bottom: 1.1em;
  }
  .note-prose :global(ul) { list-style-type: disc; }
  .note-prose :global(ol) { list-style-type: decimal; }
  .note-prose :global(li) { margin-bottom: 0.35em; padding-left: 0.2em; }
  .note-prose :global(li > ul),
  .note-prose :global(li > ol) { margin-top: 0.3em; margin-bottom: 0; }

  .note-prose :global(blockquote) {
    border-left: 3px solid rgba(208, 58, 58, 0.5);
    margin: 1.5em 0;
    padding: 0.6em 0 0.6em 1.2em;
    background: #D1D6E0;
    border-radius: 0 2px 2px 0;
    color: #373F4E;
    font-style: italic;
  }
  .note-prose :global(blockquote p) { margin-bottom: 0; }

  .note-prose :global(code) {
    background: #D1D6E0;
    border: 1px solid rgba(78, 87, 106, 0.35);
    padding: 0.15em 0.4em;
    border-radius: 2px;
    font-size: 0.82em;
    font-family: monospace;
  }

  .note-prose :global(.code-block) {
    background: #0d1117;
    border: 1px solid rgba(78, 87, 106, 0.35);
    border-radius: 4px;
    padding: 1em 1.2em;
    margin: 1.4em 0;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.65;
  }
  .note-prose :global(.code-block code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    border-radius: 0;
  }

  .note-prose :global(hr) {
    border: none;
    border-top: 2px dashed rgba(78, 87, 106, 0.35);
    margin: 2em 0;
  }

  .note-prose :global(img) {
    max-width: 100%;
    border-radius: 3px;
    border: 1px solid rgba(78, 87, 106, 0.35);
    margin: 1.2em 0;
    display: block;
  }

  .note-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    margin: 1.4em 0;
  }
  .note-prose :global(th),
  .note-prose :global(td) {
    border: 1px solid rgba(78, 87, 106, 0.35);
    padding: 0.45em 0.75em;
    text-align: left;
  }
  .note-prose :global(th) {
    background: #D1D6E0;
    color: #0A0E15;
    font-weight: 700;
  }
  .note-prose :global(tr:nth-child(even) td) {
    background: rgba(78, 87, 106, 0.06);
  }

  /* ── Tags ── */
  .note-tags-section {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 40px;
    padding-top: 28px;
  }

  .note-detail-tag {
    font-size: 0.72rem;
    font-family: monospace;
    font-weight: 500;
    padding: 3px 10px;
    background: #D1D6E0;
    color: #4E576A;
    border: 1px solid rgba(78, 87, 106, 0.35);
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .note-detail-tag:hover {
    background: #BFC6D4;
    border-color: #4E576A;
  }

  /* ── Related notes ── */
  .note-related {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 2px dashed rgba(78, 87, 106, 0.35);
  }

  .note-related-heading {
    font-family: monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0A0E15;
    margin-bottom: 20px;
  }

  .note-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }

  .note-related-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 16px 16px 32px;
    background-color: #D1D6E0;
    background-image: radial-gradient(circle, rgba(78, 87, 106, 0.12) 1px, transparent 1px);
    background-size: 14px 14px;
    border-radius: 2px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 1px 2px 6px rgba(0,0,0,0.2);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .note-related-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 18px;
    background-color: #BFC6D4;
    background-image: radial-gradient(circle, #4E576A 3px, transparent 3.5px);
    background-size: 18px 22px;
    background-repeat: repeat-y;
    background-position: center 6px;
  }

  .note-related-card::after {
    content: '';
    position: absolute;
    left: 18px; top: 0; bottom: 0;
    width: 1px;
    background: rgba(208, 58, 58, 0.45);
  }

  .note-related-card:hover {
    transform: translateY(-1px);
    box-shadow: 2px 4px 10px rgba(0,0,0,0.25);
  }

  .note-related-title {
    font-family: monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #0A0E15;
    line-height: 1.3;
  }

  .note-related-excerpt {
    font-family: monospace;
    font-size: 0.75rem;
    color: #373F4E;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Light mode ── */
  html[data-theme="light"] .note-paper-full {
    background-color: #FFFFFF;
    background-image: radial-gradient(circle, rgba(78, 87, 106, 0.16) 1px, transparent 1px);
    box-shadow: 2px 4px 12px rgba(0,0,0,0.10), 0 1px 3px rgba(0,0,0,0.06);
  }

  html[data-theme="light"] .note-paper-full::before {
    background-color: #F0F1F5;
    background-image: radial-gradient(circle, #BFC6D4 4px, transparent 4.5px);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .note-detail-container { padding: 24px 20px 64px; }
    .note-body { padding: 28px 24px 40px 36px; }
  }
</style>
