---
import { client } from "../../sanity/lib/client";
import { renderPortableText } from "../../sanity/lib/portableText";
import { getNoteBySlug } from "../../sanity/lib/documents/notes";
import PrimaryLayout from "../../layouts/primary_layout.astro";

export async function getStaticPaths() {
  const notes = await client.fetch(`*[_type == "note" && defined(slug.current)]{ "slug": slug.current }`);
  return (notes || []).map((note: any) => ({ params: { slug: note.slug } }));
}

const { slug } = Astro.params;
const note = await getNoteBySlug(slug);
const content = renderPortableText(note.content);

const maturityConfig = {
  seedling:  { emoji: "🌱", label: "Seedling"  },
  budding:   { emoji: "🌿", label: "Budding"   },
  evergreen: { emoji: "🌲", label: "Evergreen" },
};
const maturity = maturityConfig[note.maturity as keyof typeof maturityConfig] || maturityConfig.seedling;
---

<PrimaryLayout page_title={note.title}>
  <main class="page-main">
    <div class="note-detail-container">

      <a href="/garden" class="back-link">← Back to Garden</a>

      <article class="note-paper-full">
        <!-- Feed strip -->
        <div class="note-feed-strip">
          {[...Array(30)].map(() => (
            <div class="note-sprocket-hole"></div>
          ))}
        </div>

        <!-- Content -->
        <div class="note-body">
          <!-- Meta bar -->
          <div class="note-meta-row">
            {note.date && <span class="note-meta-date">{note.date}</span>}
            <span class="note-maturity-badge">
              {maturity.emoji} {maturity.label}
            </span>
          </div>

          <h1 class="note-detail-title">{note.title}</h1>

          {note.excerpt && (
            <p class="note-detail-excerpt">{note.excerpt}</p>
          )}

          <div class="note-prose" set:html={content}></div>

          {note.tags && note.tags.length > 0 && (
            <div class="note-tags-section">
              {(note.tags as string[]).map((tag) => (
                <span class="note-detail-tag">#{tag}</span>
              ))}
            </div>
          )}

          {note.relatedNotes && note.relatedNotes.length > 0 && (
            <div class="note-related">
              <h2 class="note-related-heading">Related Notes</h2>
              <div class="note-related-grid">
                {(note.relatedNotes as any[]).map((rel) => (
                  <a href={`/garden/${rel.slug}`} class="note-related-card">
                    <span class="note-related-title">{rel.title}</span>
                    {rel.excerpt && <span class="note-related-excerpt">{rel.excerpt}</span>}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Dot matrix overlay -->
        <div class="dot-matrix-overlay" aria-hidden="true"></div>
      </article>

    </div>
  </main>
</PrimaryLayout>

<style>
  .note-detail-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 24px 32px 96px;
  }

  .note-paper-full {
    position: relative;
    display: flex;
    overflow: hidden;
    background: linear-gradient(180deg, var(--note-paper) 0%, var(--note-feed) 50%, var(--note-paper) 100%);
    border: 1px solid var(--note-border);
    border-radius: 2px;
    box-shadow: 2px 4px 16px rgba(0,0,0,0.25), 0 1px 3px rgba(0,0,0,0.15);
    min-height: 600px;
  }

  .note-feed-strip {
    flex-shrink: 0;
    width: 40px;
    background: var(--note-feed);
    border-right: 1px dashed var(--note-border);
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: center;
    padding: 12px 0;
  }

  .note-sprocket-hole {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--note-sprocket);
    border: 1px solid var(--note-border);
    opacity: 0.5;
  }

  .note-body {
    flex: 1;
    padding: 48px 48px 56px 40px;
    position: relative;
    z-index: 1;
  }

  .note-meta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .note-meta-date {
    font-size: 0.72rem;
    font-family: monospace;
    color: var(--note-dimmer);
    opacity: 0.8;
  }

  .note-maturity-badge {
    font-size: 0.7rem;
    font-family: monospace;
    padding: 3px 10px;
    background: var(--note-feed);
    border: 1px solid var(--note-border);
    border-radius: 3px;
    color: var(--note-tag);
  }

  .note-detail-title {
    font-family: monospace;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--note-text);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .note-detail-excerpt {
    font-size: 1rem;
    font-family: monospace;
    color: var(--note-excerpt);
    line-height: 1.65;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 2px dashed var(--note-border);
  }

  .note-prose {
    font-family: monospace;
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--note-excerpt);
  }

  .note-prose h1, .note-prose h2, .note-prose h3 {
    color: var(--note-text);
    font-family: monospace;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .note-prose p { margin-bottom: 1em; }

  .note-prose a { color: var(--note-tag); }

  .note-prose code {
    background: var(--note-feed);
    border: 1px solid var(--note-border);
    padding: 0.1em 0.3em;
    border-radius: 2px;
    font-size: 0.85em;
  }

  .note-prose ul, .note-prose ol {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }

  .note-prose li { margin-bottom: 0.3em; }

  .note-tags-section {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 2px dashed var(--note-border);
  }

  .note-detail-tag {
    font-size: 0.75rem;
    font-family: monospace;
    padding: 3px 10px;
    background: var(--note-feed);
    color: var(--note-tag);
    border: 1px solid var(--note-border);
    border-radius: 3px;
  }

  .note-related {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 2px dashed var(--note-border);
  }

  .note-related-heading {
    font-family: monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--note-text);
    margin-bottom: 20px;
  }

  .note-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }

  .note-related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    background: var(--note-feed);
    border: 1px solid var(--note-border);
    border-radius: 2px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .note-related-card:hover { opacity: 0.8; }

  .note-related-title {
    font-family: monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--note-text);
    line-height: 1.3;
  }

  .note-related-excerpt {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--note-excerpt);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dot-matrix-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, rgba(0,0,0,0.05) 1px, transparent 1px);
    background-size: 4px 4px;
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .note-detail-container { padding: 24px 20px 64px; }
    .note-feed-strip { display: none; }
    .note-body { padding: 28px 24px 40px; }
  }
</style>
