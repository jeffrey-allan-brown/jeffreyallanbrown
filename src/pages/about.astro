---
import PrimaryLayout from "../layouts/primary_layout.astro";
import Navigation from "../components/shared/navigation.astro";
import PageHeader from "../components/shared/page_header.astro";
---
<PrimaryLayout page_title="about">
  <div class="overflow-hidden">
    <div class="relative">
      <div class="absolute inset-2 bottom-0 rounded-4xl ring-1 ring-black/5 ring-inset bg-linear-115 from-[#ffffff] from-28% via-[#F5F5F5] via-70% to-[#EBEBEB] sm:bg-linear-145"></div>
      <div class="relative px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:max-w-7xl">
          <Navigation />
        </div>
      </div>
    </div>
    <main>
      <div class="py-16">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-4xl">
            <div class="mb-12">
              <PageHeader heading="about" subheading="get to know me" content="a little bit about who I am and what I do"/>
            </div>

            <!-- Bio Section -->
            <section class="mb-16">
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-8">
                <h2 class="text-2xl font-bold text-gray-950 mb-6">Who I Am</h2>
                <div class="prose prose-gray max-w-none">
                  <p class="text-lg text-gray-700 leading-relaxed mb-4">
                    I'm a perpetual hobbyist and obsessive tinkerer specializing in problem solving and creative solutioning.
                  </p>
                  <p class="text-gray-700 leading-relaxed mb-4">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                    Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
                  </p>
                  <p class="text-gray-700 leading-relaxed">
                    Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                    Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
                  </p>
                </div>
              </div>
            </section>

            <!-- Skills Section -->
            <section class="mb-16">
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-8">
                <h2 class="text-2xl font-bold text-gray-950 mb-6">Skills & Expertise</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <h3 class="text-lg font-semibold text-gray-950 mb-3">Development</h3>
                    <div class="flex flex-wrap gap-2">
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">JavaScript</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">TypeScript</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">React</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Node.js</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Python</span>
                    </div>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold text-gray-950 mb-3">Design & Tools</h3>
                    <div class="flex flex-wrap gap-2">
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Figma</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Tailwind CSS</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Git</span>
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded border border-gray-200">Docker</span>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- Experience Section -->
            <section class="mb-16">
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-8">
                <h2 class="text-2xl font-bold text-gray-950 mb-6">Experience</h2>
                <div class="space-y-6">
                  <!-- Experience Item -->
                  <div class="border-l-4 border-gray-900 pl-4">
                    <h3 class="text-lg font-semibold text-gray-950">Senior Developer</h3>
                    <p class="text-sm text-gray-600 mb-2">Company Name · 2020 - Present</p>
                    <p class="text-gray-700">
                      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                    </p>
                  </div>

                  <!-- Experience Item -->
                  <div class="border-l-4 border-gray-300 pl-4">
                    <h3 class="text-lg font-semibold text-gray-950">Developer</h3>
                    <p class="text-sm text-gray-600 mb-2">Previous Company · 2018 - 2020</p>
                    <p class="text-gray-700">
                      Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
                    </p>
                  </div>

                  <!-- Experience Item -->
                  <div class="border-l-4 border-gray-300 pl-4">
                    <h3 class="text-lg font-semibold text-gray-950">Junior Developer</h3>
                    <p class="text-sm text-gray-600 mb-2">First Company · 2016 - 2018</p>
                    <p class="text-gray-700">
                      Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <!-- Contact/Resume Section -->
            <section class="mb-16">
              <div class="bg-gradient-to-r from-gray-900 to-gray-800 rounded-lg shadow-lg p-8 text-center">
                <h2 class="text-2xl font-bold text-white mb-4">Let's Connect</h2>
                <p class="text-gray-300 mb-6 max-w-2xl mx-auto">
                  Interested in working together or just want to chat? Feel free to reach out or download my resume.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                  <a
                    href="mailto:hello@jeffreyallanbrown.com"
                    class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-white text-gray-900 font-medium hover:bg-gray-100 transition-colors"
                  >
                    Send an Email
                  </a>
                  <a
                    href="/resume.pdf"
                    download
                    class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-transparent border-2 border-white text-white font-medium hover:bg-white hover:text-gray-900 transition-colors"
                  >
                    Download Resume
                  </a>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>
  </div>
</PrimaryLayout>
