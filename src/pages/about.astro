---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";
---

<PrimaryLayout page_title="about">
  <main class="page-main">
    <div class="about-container">

      <PageHeader
        heading="about"
        subheading="get to know me"
        content="Marketing Ops, Data Ops, and Marketing Technology"
      />

      <!-- Bio -->
      <section class="about-card">
        <h2 class="about-card-heading">Who I Am</h2>
        <div class="about-prose">
          <p>I'm a lifelong learner and perpetual tinkerer with a passion for exploring new skills and ideas—both professionally and in my personal life. Whether it's picking up a new hobby or building a digital tool from scratch, I thrive on the process of discovery and hands-on problem-solving.</p>
          <p>Empowered by technology and driven by curiosity, I make the most of available resources to better understand the world, create useful solutions, and continuously grow as a person and a professional. I refer to myself as "Marketing Ops with Developer Chops" — I'm a highly technical individual with skills in web development, data engineering, and more, and I'm comfortable rolling up my sleeves and implementing custom solutions myself when needed.</p>
        </div>
      </section>

      <!-- Proficiencies -->
      <section class="about-card">
        <h2 class="about-card-heading">Proficiencies</h2>
        <div class="skills-grid skills-grid--3">
          <div>
            <div class="skills-tags">
              <span class="skill-tag">Marketing Operations</span>
              <span class="skill-tag">Marketing Automation</span>
              <span class="skill-tag">Full-Stack Web Development</span>
            </div>
          </div>
          <div>
            <div class="skills-tags">
              <span class="skill-tag">Data Engineering</span>
              <span class="skill-tag">Full Funnel Strategy</span>
              <span class="skill-tag">Server-Side Programming</span>
            </div>
          </div>
          <div>
            <div class="skills-tags">
              <span class="skill-tag">Digital Marketing</span>
              <span class="skill-tag">Data Science & BI</span>
              <span class="skill-tag">Strategic Communication</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Technical Knowledge -->
      <section class="about-card">
        <h2 class="about-card-heading">Technical Knowledge</h2>
        <div class="tech-grid">
          <div class="tech-group">
            <h3 class="tech-category">Languages</h3>
            <p class="tech-list">HTML, CSS, Javascript, Typescript, PostCSS, SASS/SCSS, LESS, Python, SQL, NoSQL, JSON, YAML <span class="tech-in-progress">(Go, Rust, Solidity in progress)</span></p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Marketing Automation</h3>
            <p class="tech-list">Inflection, Marketo, Hubspot, Pardot, Braze, Salesforce Marketing Cloud, Customer.io, Iterable, Klaviyo, Sendgrid</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">CDPs & Tag Management</h3>
            <p class="tech-list">Segment, Rudderstack, mParticle, Amplitude, Google Tag Manager, Tealium</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Data Storage & Transformation</h3>
            <p class="tech-list">Databricks, MySQL, SQL Server, MariaDB, BigQuery, Snowflake, MongoDB, CouchDB, Redshift, PostgreSQL</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">ETL & Data Orchestration</h3>
            <p class="tech-list">Funnel.io, Tray.io, Workato, Pipedream, Zapier, Fivetran, Apache Airflow, Stitch</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Analytics & Reporting</h3>
            <p class="tech-list">Google Analytics (UA & 4), Amplitude, Mixpanel, Tableau, Microsoft Power BI, Google Data Studio</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">App Frameworks & Libraries</h3>
            <p class="tech-list">Vue, Astro, React/Next.js, Angular, Django, Flask, Gatsby</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Cloud Services</h3>
            <p class="tech-list">Firebase, AWS, Azure, Heroku, Google Cloud, Digital Ocean, Mongo Atlas, Pantheon</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">CRM</h3>
            <p class="tech-list">Salesforce, Hubspot, Zoho, SugarCRM, Freshsales</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">CMS</h3>
            <p class="tech-list">Wordpress, Contentful, Drupal, Ghost, Sharepoint, Django CMS, Hygraph, Sanity</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Virtualization & Containers</h3>
            <p class="tech-list">Docker, Kubernetes, Libvirt (KVM + QEMU), Microsoft Hyper-V, VMWare Workstation</p>
          </div>
          <div class="tech-group">
            <h3 class="tech-category">Go-To-Market Tools</h3>
            <p class="tech-list">Gainsight, Outreach, Pocus, Drift, Qualified</p>
          </div>
        </div>
      </section>

      <!-- Certifications -->
      <section class="about-card">
        <h2 class="about-card-heading">Certifications</h2>
        <div class="cert-list">
          <span class="skill-tag">Marketo Certified Solutions Architect (MCSA)</span>
          <span class="skill-tag">Marketo Certified Consultant</span>
          <span class="skill-tag">Marketo Certified Revenue Cycle Analyst</span>
          <span class="skill-tag">Segment Analytics Expert</span>
          <span class="skill-tag">Segment Implementation Expert</span>
          <span class="skill-tag">Amplitude Implementation Expert</span>
          <span class="skill-tag">Amplitude Insights Expert</span>
          <span class="skill-tag">Workato Automation Pro I, II & III</span>
          <span class="skill-tag">Certified Adobe Audience Manager Business Practitioner</span>
        </div>
      </section>

      <!-- Experience -->
      <section class="about-card">
        <h2 class="about-card-heading">Experience</h2>
        <div class="experience-list">

          <div class="experience-item experience-item--primary">
            <div class="experience-header">
              <h3 class="experience-title">Sr. Manager, Marketing Operations</h3>
              <span class="experience-period">2023 – Present</span>
            </div>
            <p class="experience-company">Mural</p>
            <ul class="experience-bullets">
              <li>Own and manage the Segment Customer Data Platform (CDP), ensuring seamless integration with downstream systems including Inflection, Marketo, Salesforce, Pocus, and Qualified</li>
              <li>Serve as the primary liaison between Data Engineering and Revenue Operations, facilitating alignment on data strategy and execution</li>
              <li>Oversee accurate capture, transformation, and orchestration of attribution data across the marketing and sales tech stack</li>
              <li>Define and maintain the event schema for go-to-market data, including a unified event taxonomy and key properties across systems</li>
              <li>Support evaluation, implementation, and onboarding of new tools within the GTM tech stack, including Salesforce Data Cloud</li>
              <li>Create and maintain SQL-based views in Databricks to support PLG data analysis and enable data activation in tools such as Gainsight</li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Director, Marketing Operations</h3>
              <span class="experience-period">2021 – 2023</span>
            </div>
            <p class="experience-company">McGaw</p>
            <ul class="experience-bullets">
              <li>Developed implementation strategies for CDPs and analytics tools including Segment, mParticle, Lytics, Amplitude, Mixpanel, and Google Analytics</li>
              <li>Connected disparate systems by creating custom integrations and data pipelines</li>
              <li>Designed, executed, and managed optimization campaigns across websites, CDPs, analytics tools, email providers, and more</li>
              <li>Developed internal MOPs and DevOps processes as well as company tools</li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Technical Architect</h3>
              <span class="experience-period">2018 – 2021</span>
            </div>
            <p class="experience-company">Reach Marketing</p>
            <ul class="experience-bullets">
              <li>Designed and developed marketing automation solutions for clients across various verticals</li>
              <li>Led implementations of Marketo and Salesforce Marketing Cloud; made strategic recommendations for martech stack enhancements</li>
              <li>Leveraged platform APIs and custom ETL solutions to connect disparate systems</li>
              <li>Served as company-wide technical consultant for web development requests</li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Marketing Automation Consultant</h3>
              <span class="experience-period">2017 – 2018</span>
            </div>
            <p class="experience-company">Fathom</p>
            <ul class="experience-bullets">
              <li>Led client account teams to implement marketing automation solutions including triggered messaging, automated lead intake, and real-time personalization</li>
              <li>Produced thought leadership content and sales support materials to drive new business</li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Marketing Automation Strategist</h3>
              <span class="experience-period">2015 – 2017</span>
            </div>
            <p class="experience-company">Fathom</p>
            <ul class="experience-bullets">
              <li>Developed messaging strategies leveraging customer personas, existing engagement data, and personalized content</li>
              <li>Designed and implemented custom marketing automation solutions spanning multiple channels and lifecycle stages</li>
              <li>Created frameworks and toolkits for campaign planning including program playbooks and implementation workbooks</li>
            </ul>
          </div>

          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Email Marketing Specialist</h3>
              <span class="experience-period">2013 – 2015</span>
            </div>
            <p class="experience-company">Fathom</p>
            <ul class="experience-bullets">
              <li>Developed marketing email and landing page assets in alignment with best practices</li>
              <li>Defined testing strategies and methodologies for optimizing asset performance using behavioral analytics tools</li>
            </ul>
          </div>

        </div>
      </section>

      <!-- Education -->
      <section class="about-card">
        <h2 class="about-card-heading">Education</h2>
        <div class="experience-list">
          <div class="experience-item experience-item--primary">
            <div class="experience-header">
              <h3 class="experience-title">B.A. in English — Rhetorical Strategy</h3>
              <span class="experience-period">2007 – 2010</span>
            </div>
            <p class="experience-company">The Ohio State University</p>
          </div>
          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">On-Site Technical & Training Seminars</h3>
              <span class="experience-period">2009 – Present</span>
            </div>
            <p class="experience-company">Marketo/Adobe Summit, Tableau Conference, and others</p>
          </div>
          <div class="experience-item">
            <div class="experience-header">
              <h3 class="experience-title">Open Source Work & Self-Study</h3>
              <span class="experience-period">Life-Long</span>
            </div>
            <p class="experience-company">MIT Open Courseware, LinkedIn Learning, Codecademy, Pluralsight, and personal projects</p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section class="contact-card">
        <h2 class="contact-heading">Let's Connect</h2>
        <p class="contact-desc">Interested in working together or just want to chat? Feel free to reach out or download my resume.</p>
        <div class="contact-actions">
          <a href="mailto:jeffrey@jeffreyallanbrown.com" class="btn-primary">Send an Email</a>
          <a href="/resume.pdf" download class="btn-outline">Download Resume</a>
        </div>
      </section>

    </div>
  </main>
</PrimaryLayout>

<style>
  .about-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .about-card {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px;
    margin-bottom: 20px;
  }

  .about-card-heading {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 20px;
  }

  .about-prose p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--dim);
    margin-bottom: 12px;
  }

  .about-prose p:last-child { margin-bottom: 0; }

  /* Proficiencies */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .skills-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .skill-tag {
    padding: 4px 12px;
    background: var(--black-80);
    color: var(--dim);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* Technical Knowledge */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 32px;
  }

  .tech-group {}

  .tech-category {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 6px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .tech-list {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--dim);
  }

  .tech-in-progress {
    color: var(--dimmer);
    font-style: italic;
  }

  /* Certifications */
  .cert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .experience-item {
    padding-left: 16px;
    border-left: 2px solid var(--border);
  }

  .experience-item--primary {
    border-left-color: var(--white);
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 2px;
  }

  .experience-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
  }

  .experience-period {
    font-size: 0.75rem;
    color: var(--dimmer);
    white-space: nowrap;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .experience-company {
    font-size: 0.8rem;
    color: var(--dimmer);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }

  .experience-bullets {
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .experience-bullets li {
    font-size: 0.83rem;
    line-height: 1.6;
    color: var(--dim);
  }

  /* Contact */
  .contact-card {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 48px 32px;
    text-align: center;
    margin-bottom: 0;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-bottom: 12px;
  }

  .contact-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--dim);
    max-width: 420px;
    margin: 0 auto 28px;
  }

  .contact-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .about-container { padding: 32px 20px 64px; }
    .skills-grid--3 { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .tech-grid { grid-template-columns: 1fr; }
    .about-card { padding: 24px; }
    .contact-card { padding: 32px 20px; }
    .experience-header { flex-direction: column; gap: 2px; }
  }
</style>
