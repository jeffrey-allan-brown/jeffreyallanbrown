---
import { client } from "../../sanity/lib/client";
import { renderMarkdown } from "../../sanity/lib/portableText";
import { getPostBySlug, getRecentPosts } from "../../sanity/lib/documents/posts";
import PrimaryLayout from "../../layouts/primary_layout.astro";

export async function getStaticPaths() {
  const posts = await client.fetch(`*[_type == "post" && defined(slug.current)]{
    "slug": slug.current
  }`);
  return (posts || []).map((post: any) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);
const content = renderMarkdown(post.content);

const allRecent = await getRecentPosts(5);
const moreArticles = allRecent.filter((p: any) => p.slug !== slug).slice(0, 2);
---

<PrimaryLayout page_title={post.title}>
  <main class="page-main">

    <!-- ── Article ── -->
    <article class="post-article">

      <!-- Center-aligned header: date → title → author -->
      <header class="post-header">
        <time class="post-date">{post.date}</time>
        <h1 class="post-title">{post.title}</h1>
        {post.author && (
          <div class="post-byline">
            {post.author.image && (
              <img src={post.author.image} alt={post.author.name} class="post-author-avatar" />
            )}
            <span>by {post.author.name}</span>
          </div>
        )}
      </header>

      <!-- Body: banner + prose, capped at max-w-3xl -->
      <div class="post-body">
        {post.banner?.url && (
          <div class="post-banner-wrap">
            <img
              src={post.banner.url}
              alt={post.banner.alt ?? ''}
              class="post-banner-img"
            />
          </div>
        )}
        <div class="prose post-prose" set:html={content}></div>
      </div>
    </article>

    <!-- ── More articles ── -->
    {moreArticles.length > 0 && (
      <section class="more-section">
        <div class="more-inner">
          <h2 class="more-heading">More articles</h2>
          <div class="more-grid">
            {moreArticles.map((article: any) => (
              <article class="more-card">
                <div class="more-card-inner">
                  <time class="more-card-date">{article.date}</time>
                  <h3 class="more-card-title">{article.title}</h3>
                  {article.summary && (
                    <p class="more-card-excerpt">{article.summary}</p>
                  )}
                  <a href={`/blog/${article.slug}`} class="more-card-link" aria-label={`Read more: ${article.title}`}>
                    Read more
                    <svg viewBox="0 0 24 6" aria-hidden="true" class="more-card-arrow">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M24 3 18 .5v2H0v1h18v2L24 3Z"></path>
                    </svg>
                    <span class="absolute inset-0"></span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</PrimaryLayout>

<style>
  /* ── Article container ── */
  .post-article {
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 32px 96px;
  }

  /* ── Header: center-aligned ── */
  .post-header {
    max-width: 860px;
    margin: 0 auto 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dimmer);
    margin-bottom: 24px;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--white);
    text-wrap: balance;
    margin-bottom: 32px;
  }

  .post-byline {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--dim);
    letter-spacing: 0.02em;
  }

  .post-author-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  /* ── Body: narrow prose column ── */
  .post-body {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Banner image */
  .post-banner-wrap {
    margin-bottom: 48px;
    border-radius: 18px;
    overflow: hidden;
    background: var(--black-80);
  }

  .post-banner-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    filter: grayscale(0.25);
    transition: filter 0.5s ease;
  }

  .post-banner-wrap:hover .post-banner-img {
    filter: grayscale(0);
  }

  /* Inline images inside prose — same rounded grayscale treatment */
  .post-prose :global(img) {
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    filter: grayscale(0.25);
    transition: filter 0.5s ease;
    margin: 32px 0;
  }

  .post-prose :global(img:hover) {
    filter: grayscale(0);
  }

  /* ── More articles ── */
  .more-section {
    border-top: 1px solid var(--border);
    padding: 64px 32px 80px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .more-inner {
    max-width: 1140px;
  }

  .more-heading {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--white);
    margin-bottom: 48px;
  }

  .more-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 1024px) {
    .more-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Each card: left-side L-shaped border (solid top + faded tail) */
  .more-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: 28px;
  }

  .more-card-inner::before,
  .more-card-inner::after {
    content: '';
    position: absolute;
    left: 0;
    width: 1px;
  }

  .more-card-inner::before {
    top: 0;
    height: 28px;
    background: var(--white);
  }

  .more-card-inner::after {
    top: 36px;
    bottom: 0;
    background: var(--border);
  }

  .more-card-date {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dimmer);
    margin-bottom: 10px;
  }

  .more-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.45;
    margin-bottom: 10px;
    margin-top: 4px;
  }

  .more-card-excerpt {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--dim);
    margin-bottom: 20px;
    flex: 1;
  }

  .more-card-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--white);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .more-card-link:hover { color: var(--dim); }

  .more-card-arrow {
    width: 20px;
    flex-shrink: 0;
    fill: currentColor;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post-article { padding: 40px 20px 64px; }
    .post-header { margin-bottom: 48px; }
    .more-section { padding: 48px 20px 64px; }
  }
</style>
