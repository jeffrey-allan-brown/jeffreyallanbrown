---
import { getRecentPosts } from "../sanity/lib/documents/posts";
import { getBooks }       from "../sanity/lib/documents/books";
import { getAlbums }      from "../sanity/lib/documents/music";
import { getNotes }       from "../sanity/lib/documents/notes";

const recentPosts  = await getRecentPosts(3);
const allBooks     = await getBooks();
const recentBooks  = allBooks.slice(0, 5);
const allAlbums    = await getAlbums();
const recentAlbums = allAlbums.slice(0, 5);
const allNotes     = await getNotes();
const recentNotes  = allNotes.slice(0, 6);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Jeffrey Allan Brown</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function(){const t=localStorage.getItem('theme');if(t!=='dark')document.documentElement.setAttribute('data-theme','light');})();
    </script>
  </head>
  <body>

    <div class="frame"></div>

    <header>
      <div class="header-inner">
        <a href="/" class="logo">jeffrey.</a>
        <nav id="main-nav">
          <a href="/media">media</a>
          <a href="/garden">garden</a>
          <a href="/projects">projects</a>
          <a href="/thoughts">thoughts</a>
          <a href="/about">about</a>
        </nav>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="4.5"/>
            <line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <section class="hero">
      <div class="hero-meta">
        <span>Obsessive Tinkerer</span>
        <span class="sep">&#47;</span>
        <span>Perpetual Hobbyist</span>
        <span class="sep">&#47;</span>
        <span>Curious Technologist</span>
      </div>

      <h1 class="hero-headline">
        Hello, I'm<br /><span class="glitch" data-text="Jeffrey.">Jeffrey.</span>
      </h1>

      <div class="hero-footer">
        <hr class="hero-rule" />
        <div class="hero-footer-inner">
          <p class="hero-description">
            Problem solver and creative thinker building at the intersection of technology, design, and curiosity.
          </p>
          <div class="hero-links">
            <a href="/projects">Projects →</a>
            <a href="/about">About →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="posts">
      <div class="posts-header">
        <div class="posts-label">Recent Writing</div>
        <a href="/blog" class="posts-view-all">View all →</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map((post: any) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            {post.thumbnail && (
              <div class="post-thumb">
                <img src={post.thumbnail} alt={post.title} />
              </div>
            )}
            <div class="post-body">
              <div class="post-date">{post.date}</div>
              <div class="post-title">{post.title}</div>
              {post.summary && <div class="post-summary">{post.summary}</div>}
              {post.author && (
                <div class="post-author">
                  {post.author.image && <img src={post.author.image} alt={post.author.name} />}
                  <span>{post.author.name}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Recently Read Books ── -->
    <section class="shelf">
      <div class="section-header">
        <div class="section-label">Recently Read</div>
        <a href="/media" class="section-link">View all →</a>
      </div>
      <div class="books-grid">
        {recentBooks.map((book: any) => (
          <div class="book-card" data-cover={book.cover || ''} data-slug={book.slug}>
            <div class="book-canvas-wrap">
              <canvas class="book-canvas"></canvas>
            </div>
            <a href={`/books/${book.slug}`} class="book-info">
              <div class="book-title">{book.title}</div>
              <div class="book-author">{book.author}</div>
              {book.yearRead && <div class="book-year">{book.yearRead}</div>}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Recently Listened ── -->
    <section class="shelf">
      <div class="section-header">
        <div class="section-label">Recently Listened</div>
        <a href="/media" class="section-link">View all →</a>
      </div>
      <div class="albums-grid">
        {recentAlbums.map((album: any) => (
          <div class="album-card" data-cover={album.cover || ''} data-slug={album.slug}>
            <div class="album-canvas-wrap">
              <canvas class="album-canvas"></canvas>
            </div>
            <a href={`/albums/${album.slug}`} class="album-info">
              {album.currentlyListening && <span class="album-now-playing">Now Playing</span>}
              <div class="album-title">{album.title}</div>
              <div class="album-artist">{album.artist}</div>
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Digital Garden ── -->
    <section class="shelf">
      <div class="section-header">
        <div class="section-label">Digital Garden</div>
        <a href="/garden" class="section-link">View all →</a>
      </div>
      <div class="notes-grid">
        {recentNotes.map((note: any) => (
          <a href={`/garden/${note.slug}`} class="note-card">
            <div class="note-maturity">
              {note.maturity === 'seedling'  && <span title="Seedling">🌱</span>}
              {note.maturity === 'budding'   && <span title="Budding">🌿</span>}
              {note.maturity === 'evergreen' && <span title="Evergreen">🌲</span>}
            </div>
            <div class="note-title">{note.title}</div>
            {note.excerpt && <div class="note-excerpt">{note.excerpt}</div>}
            {note.tags && note.tags.length > 0 && (
              <div class="note-tags">
                {note.tags.slice(0, 3).map((tag: string) => (
                  <span class="note-tag">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>

  <script>
    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
      header?.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });

    // Theme toggle
    const themeBtn = document.getElementById('theme-toggle');
    const html = document.documentElement;
    themeBtn?.addEventListener('click', () => {
      const isLight = html.getAttribute('data-theme') === 'light';
      if (isLight) {
        html.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        html.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
    });

    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('main-nav');
    toggle?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open');
      toggle.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    });
    nav?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        nav.classList.remove('open');
        toggle?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  </script>

  <script>
    (function () {
      const canvas = document.createElement('canvas');
      canvas.style.cssText = 'position:fixed;top:0;left:0;pointer-events:none;z-index:9999;';
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      document.body.appendChild(canvas);

      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      const mouse = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
      let mouseMoving = false;
      let timer: ReturnType<typeof setTimeout>;

      const trail = new Array(4).fill(null).map(() => ({
        x: Math.random() * window.innerWidth - window.innerWidth / 2,
        y: Math.random() * window.innerHeight - window.innerHeight / 2,
        dx: 0,
        dy: 0,
      }));

      window.addEventListener('mousemove', (e) => {
        mouseMoving = true;
        clearTimeout(timer);
        timer = setTimeout(() => { mouseMoving = false; }, 100);
        mouse.x = e.clientX;
        mouse.y = e.clientY;
      });

      window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      });

      function draw() {
        requestAnimationFrame(draw);

        if (mouseMoving) {
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          trail.forEach((point, i) => {
            const target = i === 0 ? mouse : trail[i - 1];
            point.dx += 0.3 * (target.x - point.x) + 2 * Math.random();
            point.dy += 0.3 * (target.y - point.y) + 2 * Math.random();
            point.dx *= 0.5;
            point.dy *= 0.5;
            point.x += point.dx;
            point.y += point.dy;
          });

          ctx.beginPath();
          ctx.moveTo(trail[0].x + 2 * Math.random(), trail[0].y + 2 * Math.random());

          for (let i = 0; i < trail.length - 1; i++) {
            const mx = 0.5 * (trail[i].x + trail[i + 1].x + 2 * Math.random());
            const my = 0.5 * (trail[i].y + trail[i + 1].y + 2 * Math.random());
            ctx.quadraticCurveTo(
              trail[i].x + 50 * Math.random() - 25,
              trail[i].y + 50 * Math.random() - 25,
              mx, my
            );
            ctx.strokeStyle = document.documentElement.getAttribute('data-theme') === 'light'
              ? 'rgba(0,0,0,0.5)' : 'rgba(255,255,255,0.85)';
            ctx.lineWidth = 3;
            ctx.stroke();
          }

          ctx.lineTo(trail[trail.length - 1].x, trail[trail.length - 1].y);
          ctx.stroke();
        } else {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
      }

      draw();
    })();
  </script>

  <script>
    import * as THREE from 'three';
    import { OrbitControls }  from 'three/addons/controls/OrbitControls.js';
    import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

    document.querySelectorAll<HTMLCanvasElement>('.book-canvas').forEach((canvas) => {
      const card = canvas.closest('.book-card') as HTMLElement;
      if (!card) return;

      const cover = card.dataset.cover || '';
      const wrap  = canvas.parentElement as HTMLElement;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.outputColorSpace    = THREE.SRGBColorSpace;
      renderer.toneMapping         = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.3;

      const pmrem = new THREE.PMREMGenerator(renderer);

      const scene  = new THREE.Scene();
      scene.environmentIntensity = 0.7;

      // Immediate fallback: room environment so book looks good before image loads
      scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

      // Upgrade to equirectangular library image for real reflections + background
      new THREE.TextureLoader().load('/library-env.jpg', (tex) => {
        tex.mapping    = THREE.EquirectangularReflectionMapping;
        tex.colorSpace = THREE.SRGBColorSpace;
        scene.environment          = pmrem.fromEquirectangular(tex).texture;
        scene.background           = tex;
        scene.backgroundBlurriness = 0.05;
        pmrem.dispose();
      });

      const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 20);
      camera.position.set(0, 0.05, 2.2);

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping  = true;
      controls.dampingFactor  = 0.07;
      controls.enablePan      = false;
      controls.minDistance    = 1.1;
      controls.maxDistance    = 4.5;
      controls.target.set(0, 0, 0);
      controls.update();

      // Minimal directional lights — env map handles most of the ambient/reflection
      const key = new THREE.DirectionalLight(0xfff8f0, 1.4);
      key.position.set(3, 6, 4);
      scene.add(key);
      const fill = new THREE.DirectionalLight(0xd0e4ff, 0.4);
      fill.position.set(-4, 2, 2);
      scene.add(fill);

      const BW = 0.65, BH = 1.0, BD = 0.14;
      const BOARD = 0.009, FORE = 0.016, HEAD = 0.013;

      // Procedural page-edge texture (cream + faint horizontal lines)
      const pageTex = (() => {
        const c = document.createElement('canvas');
        c.width = 64; c.height = 512;
        const cx = c.getContext('2d')!;
        cx.fillStyle = '#ebe5d5';
        cx.fillRect(0, 0, 64, 512);
        for (let i = 0; i < 210; i++) {
          const y = (i / 210) * 512 + (Math.random() - 0.5) * 1.5;
          cx.strokeStyle = `rgba(140,118,80,${0.06 + Math.random() * 0.09})`;
          cx.lineWidth = 0.5 + Math.random() * 0.5;
          cx.beginPath(); cx.moveTo(0, y); cx.lineTo(64, y); cx.stroke();
        }
        return new THREE.CanvasTexture(c);
      })();

      const pageEdgeMat  = new THREE.MeshStandardMaterial({ map: pageTex, roughness: 0.92 });
      const pageBodyMat  = new THREE.MeshStandardMaterial({ color: 0xebe5d5, roughness: 0.95 });
      const coverMat     = new THREE.MeshPhysicalMaterial({ color: 0x444444, roughness: 0.35, metalness: 0.0, clearcoat: 0.6, clearcoatRoughness: 0.12 });
      const coverEdgeMat = new THREE.MeshStandardMaterial({ color: 0x1e1e1e, roughness: 0.75 });
      const spineOutMat  = new THREE.MeshPhysicalMaterial({ color: 0x181818, roughness: 0.55, clearcoat: 0.35, clearcoatRoughness: 0.25 });
      const backMat      = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.85 });

      if (cover) {
        const coverLoader = new THREE.TextureLoader();
        coverLoader.crossOrigin = 'anonymous';
        coverLoader.load(cover, (tex: THREE.Texture) => {
          tex.colorSpace      = THREE.SRGBColorSpace;
          coverMat.map        = tex;
          coverMat.color.setHex(0xffffff);
          coverMat.needsUpdate = true;
        });
      }

      // Page block — fore-edge (+x), head (+y), tail (-y) show page lines
      const PW = BW - BOARD - FORE;
      const PH = BH - HEAD * 2;
      const PD = BD - BOARD * 2;

      const book = new THREE.Group();

      // Page block — fore-edge (+x), head (+y), tail (-y) show page lines
      const pageMesh = new THREE.Mesh(
        new THREE.BoxGeometry(PW, PH, PD),
        [pageEdgeMat, pageBodyMat, pageEdgeMat, pageEdgeMat, pageBodyMat, pageBodyMat],
      );
      pageMesh.position.x = (BOARD - FORE) / 2;
      book.add(pageMesh);

      // Front cover board
      const frontBoard = new THREE.Mesh(
        new THREE.BoxGeometry(BW, BH, BOARD),
        [coverEdgeMat, coverEdgeMat, coverEdgeMat, coverEdgeMat, coverMat, pageBodyMat],
      );
      frontBoard.position.z = PD / 2 + BOARD / 2;
      book.add(frontBoard);

      // Back cover board
      const backBoard = new THREE.Mesh(
        new THREE.BoxGeometry(BW, BH, BOARD),
        [coverEdgeMat, coverEdgeMat, coverEdgeMat, coverEdgeMat, pageBodyMat, backMat],
      );
      backBoard.position.z = -(PD / 2 + BOARD / 2);
      book.add(backBoard);

      // Spine board
      const spineBoard = new THREE.Mesh(
        new THREE.BoxGeometry(BOARD, BH, BD),
        [pageBodyMat, spineOutMat, coverEdgeMat, coverEdgeMat, coverEdgeMat, coverEdgeMat],
      );
      spineBoard.position.x = -(BW - BOARD) / 2;
      book.add(spineBoard);

      book.rotation.y = 0.15;
      scene.add(book);

      function resize() {
        const w = wrap.clientWidth;
        const h = wrap.clientHeight;
        if (!w || !h) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      new ResizeObserver(resize).observe(wrap);

      let hovered    = false;
      let dragging   = false;
      let wobbleAmt  = 0;
      let wobblePhase = 0;

      wrap.addEventListener('mouseenter', () => { hovered = true; });
      wrap.addEventListener('mouseleave', () => { hovered = false; });
      controls.addEventListener('start',  () => { dragging = true; });
      controls.addEventListener('end',    () => { dragging = false; });

      (function animate() {
        requestAnimationFrame(animate);
        controls.update();

        const shouldWobble = hovered && !dragging;
        wobbleAmt += ((shouldWobble ? 1 : 0) - wobbleAmt) * 0.05;

        if (wobbleAmt > 0.001) {
          wobblePhase += 0.022;
          book.rotation.y = 0.15 + Math.sin(wobblePhase * 1.4)  * 0.22 * wobbleAmt;
          book.rotation.x =        Math.sin(wobblePhase * 1.0)  * 0.10 * wobbleAmt;
          book.rotation.z =        Math.sin(wobblePhase * 0.75) * 0.04 * wobbleAmt;
        } else {
          book.rotation.y += (0.15 - book.rotation.y) * 0.1;
          book.rotation.x += (0    - book.rotation.x) * 0.1;
          book.rotation.z += (0    - book.rotation.z) * 0.1;
        }

        renderer.render(scene, camera);
      })();
    });
  </script>
  <script>
    import * as THREE from 'three';
    import { OrbitControls }   from 'three/addons/controls/OrbitControls.js';
    import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

    document.querySelectorAll<HTMLCanvasElement>('.album-canvas').forEach((canvas) => {
      const card = canvas.closest('.album-card') as HTMLElement;
      if (!card) return;

      const cover = card.dataset.cover || '';
      const wrap  = canvas.parentElement as HTMLElement;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.outputColorSpace    = THREE.SRGBColorSpace;
      renderer.toneMapping         = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;

      const pmrem = new THREE.PMREMGenerator(renderer);
      const scene  = new THREE.Scene();
      scene.environmentIntensity = 0.8;
      scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

      new THREE.TextureLoader().load('/music-env.jpg', (tex) => {
        tex.mapping    = THREE.EquirectangularReflectionMapping;
        tex.colorSpace = THREE.SRGBColorSpace;
        scene.environment            = pmrem.fromEquirectangular(tex).texture;
        scene.background             = tex;
        scene.backgroundBlurriness   = 0.05;
        scene.backgroundRotation.y   = Math.PI * 0.75; // 135°
        pmrem.dispose();
      });

      const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 20);
      camera.position.set(0, 0, 2.1);

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.07;
      controls.enablePan     = false;
      controls.minDistance   = 1.1;
      controls.maxDistance   = 4.5;
      controls.target.set(0, 0, 0);
      controls.update();

      const key = new THREE.DirectionalLight(0xfff8f0, 1.2);
      key.position.set(3, 5, 4);
      scene.add(key);
      const fill = new THREE.DirectionalLight(0xd0e4ff, 0.35);
      fill.position.set(-4, 2, 2);
      scene.add(fill);

      // ── Sleeve ───────────────────────────────────────────────────────────

      const SW = 1.0, SH = 1.0, SD = 0.045;

      const coverMat = new THREE.MeshPhysicalMaterial({
        color: 0x888888, roughness: 0.55, metalness: 0.0,
        clearcoat: 0.2, clearcoatRoughness: 0.4,
      });
      if (cover) {
        const coverLoader = new THREE.TextureLoader();
        coverLoader.crossOrigin = 'anonymous';
        coverLoader.load(cover, (tex: THREE.Texture) => {
          tex.colorSpace      = THREE.SRGBColorSpace;
          coverMat.map        = tex;
          coverMat.color.setHex(0xffffff);
          coverMat.needsUpdate = true;
        });
      }

      const edgeMat  = new THREE.MeshStandardMaterial({ color: 0x1e1e1e, roughness: 0.85 });
      const backMat  = new THREE.MeshStandardMaterial({ color: 0x141414, roughness: 0.9  });
      const vinylMat = new THREE.MeshPhysicalMaterial({
        color: 0x080808, roughness: 0.04, metalness: 0.6,
        clearcoat: 1.0, clearcoatRoughness: 0.04,
      });
      const labelMat = new THREE.MeshStandardMaterial({ color: 0xd4c89a, roughness: 0.75 });

      const sleeve = new THREE.Group();

      // Sleeve body — +z = cover front, -z = back
      const sleeveBody = new THREE.Mesh(
        new THREE.BoxGeometry(SW, SH, SD),
        [edgeMat, edgeMat, edgeMat, edgeMat, coverMat, backMat],
      );
      sleeve.add(sleeveBody);

      // Vinyl disc — peeks above the sleeve top (y > 0.5)
      const disc = new THREE.Mesh(
        new THREE.CylinderGeometry(0.46, 0.46, 0.025, 52),
        vinylMat,
      );
      disc.rotation.x = Math.PI / 2;
      disc.position.set(0, 0.12, 0);
      sleeve.add(disc);

      // Centre label
      const label = new THREE.Mesh(
        new THREE.CylinderGeometry(0.11, 0.11, 0.026, 32),
        labelMat,
      );
      label.rotation.x = Math.PI / 2;
      label.position.set(0, 0.12, 0.001);
      sleeve.add(label);

      // Spindle hole
      const hole = new THREE.Mesh(
        new THREE.CylinderGeometry(0.014, 0.014, 0.027, 16),
        new THREE.MeshStandardMaterial({ color: 0x050505 }),
      );
      hole.rotation.x = Math.PI / 2;
      hole.position.set(0, 0.12, 0.002);
      sleeve.add(hole);

      sleeve.rotation.y = 0.1;
      scene.add(sleeve);

      function resize() {
        const w = wrap.clientWidth;
        const h = wrap.clientHeight;
        if (!w || !h) return;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      }
      resize();
      new ResizeObserver(resize).observe(wrap);

      let hovered     = false;
      let dragging    = false;
      let wobbleAmt   = 0;
      let wobblePhase = 0;

      wrap.addEventListener('mouseenter', () => { hovered = true; });
      wrap.addEventListener('mouseleave', () => { hovered = false; });
      controls.addEventListener('start',  () => { dragging = true; });
      controls.addEventListener('end',    () => { dragging = false; });

      (function animate() {
        requestAnimationFrame(animate);
        controls.update();

        const shouldWobble = hovered && !dragging;
        wobbleAmt += ((shouldWobble ? 1 : 0) - wobbleAmt) * 0.05;

        if (wobbleAmt > 0.001) {
          wobblePhase += 0.022;
          sleeve.rotation.y = 0.1 + Math.sin(wobblePhase * 1.4)  * 0.22 * wobbleAmt;
          sleeve.rotation.x =       Math.sin(wobblePhase * 1.0)  * 0.08 * wobbleAmt;
          sleeve.rotation.z =       Math.sin(wobblePhase * 0.75) * 0.03 * wobbleAmt;
        } else {
          sleeve.rotation.y += (0.1 - sleeve.rotation.y) * 0.1;
          sleeve.rotation.x += (0   - sleeve.rotation.x) * 0.1;
          sleeve.rotation.z += (0   - sleeve.rotation.z) * 0.1;
        }

        renderer.render(scene, camera);
      })();
    });
  </script>
