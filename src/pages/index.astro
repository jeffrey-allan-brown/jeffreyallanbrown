            ) : (
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {recentNotes.map((note: any) => {
                  const maturityData = maturityConfig[note.maturity as keyof typeof maturityConfig];
                  return (
                    <a href={`/garden/${note.slug}`} class="group">
                      <div class="relative overflow-hidden rounded-lg bg-gradient-to-b from-[#f5f5f5] via-[#e8e8e8] to-[#f5f5f5] border border-[#d0d0d0] transition-all hover:shadow-md p-6">
                        {maturityData && (
                          <div class="absolute top-4 right-4">
                            <span class={`text-sm bg-green-50 border-green-200 px-2 py-1 rounded border`}>
                              {maturityData.emoji}
                            </span>
                          </div>
                        )}
                        <h4 class="text-lg font-mono font-bold text-[#1a1a1a] line-clamp-2 pr-10 mb-3">{note.title}</h4>
                        {note.excerpt && (
                          <p class="text-sm font-mono text-[#555] leading-relaxed line-clamp-3 mb-4">{note.excerpt}</p>
                        )}
                        {note.tags && note.tags.length > 0 && (
                          <div class="flex flex-wrap gap-1 mt-4">
                            {note.tags.slice(0, 2).map((tag: string) => (
                              <span class="text-xs font-mono px-2 py-0.5 bg-[#e0e0e0] text-[#555] border border-[#d0d0d0] rounded">
                                #{tag}
                              </span>
                            ))}
                            {note.tags.length > 2 && (
                              <span class="text-xs font-mono text-[#666]">
                                +{note.tags.length - 2}
                              </span>
                            )}
                          </div>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      </div>

