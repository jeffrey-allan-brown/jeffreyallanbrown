    19.8% { opacity: 1; transform: translate(-4px, 0); clip-path: inset(72% 0 8%  0); }
    20%   { opacity: 0; }
    /* burst 2 */
    52.2% { opacity: 1; transform: translate(7px,  0); clip-path: inset(18% 0 72% 0); }
    52.5% { opacity: 1; transform: translate(10px, 0); clip-path: inset(58% 0 28% 0); }
    52.8% { opacity: 1; transform: translate(4px,  0); clip-path: inset(82% 0 4%  0); }
    53%   { opacity: 0; }
    /* burst 3 */
    82.2% { opacity: 1; transform: translate(-8px, 0); clip-path: inset(28% 0 62% 0); }
    82.5% { opacity: 1; transform: translate(5px,  0); clip-path: inset(8%  0 82% 0); }
    82.8% { opacity: 1; transform: translate(-3px, 0); clip-path: inset(52% 0 22% 0); }
    83%   { opacity: 0; }
  }

  @keyframes glitch-c {
