                <h3 class="mt-2 text-4xl font-medium tracking-tighter text-gray-950 sm:text-5xl">Recent Notes</h3>
              </div>
              <a href="/garden" class="text-sm font-medium text-gray-950 hover:text-gray-600 transition-colors">View all →</a>
