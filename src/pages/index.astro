---
import PrimaryLayout from "../layouts/primary_layout.astro";
import Navigation from "../components/shared/navigation.astro";
import FeaturedArticle from "../components/blog/featuredArticle.astro";
import { getRecentPosts } from "../sanity/lib/documents/posts";
import { getBooks } from "../sanity/lib/documents/books";
import { getAlbums } from "../sanity/lib/documents/music";
import { getNotes } from "../sanity/lib/documents/notes";

type Post = {
  _id: string;
  title: string;
  author: {
    name: string;
    image: string;
  };
  summary: string;
  date: string;
  thumbnail: string;
  slug: string;
};

const recentPosts: Post[] = await getRecentPosts(3);
const allBooks = await getBooks();
const recentBooks = allBooks.slice(0, 3);
const allAlbums = await getAlbums();
const recentAlbums = allAlbums.slice(0, 3);
const allNotes = await getNotes();
const recentNotes = allNotes.slice(0, 3);

const maturityConfig = {
  seedling: { emoji: "🌱", label: "Seedling" },
  budding: { emoji: "🌿", label: "Budding" },
  evergreen: { emoji: "🌲", label: "Evergreen" }
};
---
<PrimaryLayout page_title="homepage">
  <div class="overflow-hidden">
    <div class="relative">
      <div class="absolute inset-2 bottom-0 rounded-4xl ring-1 ring-black/5 ring-inset bg-linear-115 from-[#ffffff] from-28% via-[#F5F5F5] via-70% to-[#EBEBEB] sm:bg-linear-145"></div>
      <div class="relative px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:max-w-7xl">
          <Navigation />
          <div class="pt-16 pb-24 sm:pt-24 sm:pb-32 md:pt-32 md:pb-48">
            <h1 class="font-flagfies text-6xl/[0.9] text-gray-950 sm:text-8xl/[0.8] md:text-9xl/[0.8]">Hello, I'm Jeffrey.</h1>
            <p class="font-light mt-8 max-w-xl text-xl/7 text-gray-950/75 sm:text-3xl/8">I'm a perpetual hobbyist and obsessive tinkerer specializing in problem solving and creative solutioning.</p>
            <!-- <div class="mt-12 flex flex-col gap-x-6 gap-y-4 sm:flex-row">
              <a class="inline-flex items-center justify-center px-4 py-[calc(--spacing(2)-1px)] rounded-full border border-transparent bg-gray-950 shadow-md text-base font-medium whitespace-nowrap text-white data-disabled:bg-gray-950 data-disabled:opacity-40 data-hover:bg-gray-800" data-headlessui-state="" href="#">cta one</a>
              <a class="relative inline-flex items-center justify-center px-4 py-[calc(--spacing(2)-1px)] rounded-full border border-transparent bg-white/15 shadow-md ring-1 ring-[#000000]/15 after:absolute after:inset-0 after:rounded-full after:shadow-[inset_0_0_2px_1px_#ffffff4d] text-base font-medium whitespace-nowrap text-gray-950 data-disabled:bg-white/15 data-disabled:opacity-40 data-hover:bg-white/20" data-headlessui-state="" href="/">cta two</a>
            </div> -->
          </div>
        </div>
      </div>
    </div>
    <main>
      <div class="py-8 sm:py-12">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:max-w-7xl">
            <div class="mb-8">
              <h2 class="font-mono text-xs/5 font-semibold tracking-widest text-gray-500 uppercase">Recent Writing</h2>
              <h3 class="mt-2 text-4xl font-medium tracking-tighter text-gray-950 sm:text-5xl">Latest Thoughts</h3>
            </div>
            {recentPosts.length === 0 ? (
              <div class="text-gray-500">Posts coming soon</div>
            ) : (
              <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
                {recentPosts.map(post => (
                  <FeaturedArticle
                    key={post._id}
                    title={post.title}
                    author={post.author}
                    thumbnail={post.thumbnail}
                    slug={post.slug}
                    summary={post.summary}
                    date={post.date}
                  />
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Recent Books -->
      <div class="py-8 sm:py-12 bg-gray-50">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:max-w-7xl">
            <div class="mb-8 flex items-end justify-between">
              <div>
                <h2 class="font-mono text-xs/5 font-semibold tracking-widest text-gray-500 uppercase">Reading List</h2>
                <h3 class="mt-2 text-4xl font-medium tracking-tighter text-gray-950 sm:text-5xl">Recently Read Books</h3>
              </div>
              <a href="/media" class="text-sm font-medium text-gray-950 hover:text-gray-600 transition-colors">View all →</a>
            </div>
            {recentBooks.length === 0 ? (
              <div class="text-gray-500">No books yet</div>
            ) : (
              <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                {recentBooks.map((book: any) => (
                  <a href={`/books/${book.slug}`} class="group">
                    <div class="relative overflow-hidden rounded-lg bg-white shadow-sm ring-1 ring-black/5 transition-all hover:shadow-md">
                      {book.currentlyReading && (
                        <div class="absolute top-2 right-2 z-10 bg-blue-500 text-white text-[10px] font-semibold px-1.5 py-0.5 rounded-full shadow-lg">
                          Reading
                        </div>
                      )}
                      <div class="aspect-[2/3] overflow-hidden bg-gray-100">
                        <img src={book.cover} alt={book.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform" />
                      </div>
                      <div class="p-2">
                        <h4 class="text-sm font-semibold text-gray-950 line-clamp-1">{book.title}</h4>
                        <p class="mt-0.5 text-xs text-gray-600 line-clamp-1">{book.author}</p>
                        {book.yearRead && (
                          <p class="mt-1 text-[10px] text-gray-500">{book.yearRead}</p>
                        )}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Recent Music -->
      <div class="py-8 sm:py-12">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:max-w-7xl">
            <div class="mb-8 flex items-end justify-between">
              <div>
                <h2 class="font-mono text-xs/5 font-semibold tracking-widest text-gray-500 uppercase">Music</h2>
