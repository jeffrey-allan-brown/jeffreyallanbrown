                          Listening
                        </div>
                      )}
                      <div class="aspect-square overflow-hidden bg-gray-100">
                        <img src={album.cover} alt={album.title} class="h-full w-full object-cover group-hover:scale-105 transition-transform" />
                      </div>
                      <div class="p-2">
                        <h4 class="text-sm font-semibold text-gray-950 line-clamp-1">{album.title}</h4>
                        <p class="mt-0.5 text-xs text-gray-600 line-clamp-1">{album.artist}</p>
                        {album.yearListened && (
                          <p class="mt-1 text-[10px] text-gray-500">{album.yearListened}</p>
                        )}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Recent Notes -->
      <div class="py-8 sm:py-12 bg-gray-50">
        <div class="px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:max-w-7xl">
