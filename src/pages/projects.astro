---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";

import { getProjects } from "../sanity/lib/documents/projects";
const projects = await getProjects();

const statusConfig: Record<string, { label: string; color: string }> = {
  'in-progress': { label: 'In Progress', color: 'status-progress' },
  'completed':   { label: 'Completed',   color: 'status-done'     },
  'archived':    { label: 'Archived',    color: 'status-archived' },
};
---

<PrimaryLayout page_title="projects">
  <main class="page-main">
    <div class="projects-container">

      <PageHeader
        heading="projects"
        subheading="things i've built"
        content="a collection of projects I've worked on"
      />

      {projects.length > 0 ? (
        <div class="projects-grid">
          {(projects as any[]).map((project) => {
            const status = statusConfig[project.status as string];
            return (
              <a href={`/projects/${project.slug}`} class="project-card">
                {project.thumbnail && (
                  <div class="project-thumb">
                    <img src={project.thumbnail} alt={project.title} />
                  </div>
                )}
                <div class="project-body">
                  {status && (
                    <span class={`project-status ${status.color}`}>{status.label}</span>
                  )}
                  <h3 class="project-title">{project.title}</h3>
                  {project.description && (
                    <p class="project-desc">{project.description}</p>
                  )}
                  {project.technologies && project.technologies.length > 0 && (
                    <div class="project-tech">
                      {(project.technologies as string[]).slice(0, 4).map((tech) => (
                        <span class="tech-tag">{tech}</span>
                      ))}
                      {project.technologies.length > 4 && (
                        <span class="tech-more">+{project.technologies.length - 4}</span>
                      )}
                    </div>
                  )}
                  <div class="project-links">
                    {project.projectUrl && <span class="project-link-label">Live Demo →</span>}
                    {project.githubUrl && <span class="project-link-label">GitHub →</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="projects-empty">
          <p>No projects yet... 🚀</p>
        </div>
      )}

    </div>
  </main>
</PrimaryLayout>

<style>
  .projects-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .project-card:hover {
    border-color: var(--dim);
    transform: translateY(-2px);
  }

  .project-thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--black-80);
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .project-card:hover .project-thumb img {
    transform: scale(1.04);
    filter: grayscale(0);
  }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px;
    flex: 1;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid;
    align-self: flex-start;
  }

  .status-progress {
    background: rgba(59, 130, 246, 0.12);
    color: #60a5fa;
    border-color: rgba(59, 130, 246, 0.3);
  }

  .status-done {
    background: rgba(34, 197, 94, 0.1);
    color: #4ade80;
    border-color: rgba(34, 197, 94, 0.25);
  }

  .status-archived {
    background: var(--black-80);
    color: var(--dimmer);
    border-color: var(--border);
  }

  .project-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .project-desc {
    font-size: 0.83rem;
    line-height: 1.6;
    color: var(--dim);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tech-tag {
    font-size: 0.65rem;
    font-weight: 500;
    padding: 2px 8px;
    background: var(--black-80);
    color: var(--dim);
    border: 1px solid var(--border);
    border-radius: 3px;
    letter-spacing: 0.04em;
  }

  .tech-more {
    font-size: 0.65rem;
    color: var(--dimmer);
    padding: 2px 0;
  }

  .project-links {
    display: flex;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .project-link-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--dim);
    transition: color 0.2s;
  }

  .project-card:hover .project-link-label { color: var(--white); }

  .projects-empty {
    padding: 80px 0;
    color: var(--dimmer);
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .projects-container { padding: 32px 20px 64px; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
