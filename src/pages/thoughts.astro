---
import PrimaryLayout from "../layouts/primary_layout.astro";
import PageHeader from "../components/shared/page_header.astro";
import FeaturedArticle from "../components/blog/featuredArticle.astro";

import { getFeaturedPosts } from "../sanity/lib/documents/posts";
let posts = await getFeaturedPosts();
---

<PrimaryLayout page_title="thoughts">
  <main class="page-main">
    <div class="thoughts-container">

      <PageHeader
        heading="thoughts"
        subheading="words i've written"
        content="long-form content where i explore ideas and concepts in more detail"
      />

      {posts.length === 0 ? (
        <div class="thoughts-empty">
          <p>Nothing written yet — check back soon.</p>
        </div>
      ) : (
        <div class="thoughts-grid">
          {(posts as any[]).map((post) => (
            <FeaturedArticle
              key={post._id}
              title={post.title}
              author={post.author}
              thumbnail={post.thumbnail}
              slug={post.slug}
              summary={post.summary}
              date={post.date}
            />
          ))}
        </div>
      )}

    </div>
  </main>
</PrimaryLayout>

<style>
  .thoughts-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 96px;
  }

  .thoughts-empty {
    padding: 80px 0;
    color: var(--dimmer);
    font-size: 0.9rem;
  }

  .thoughts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  @media (min-width: 640px) {
    .thoughts-grid { grid-template-columns: repeat(2, 1fr); gap: 40px; }
  }

  @media (min-width: 1024px) {
    .thoughts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .thoughts-container { padding: 32px 20px 64px; }
  }
</style>
