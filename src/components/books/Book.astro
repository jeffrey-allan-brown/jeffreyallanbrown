---
const { cover, title, author, slug, currentlyReading } = Astro.props;
---

<div class="w-full max-w-xs sm:max-w-sm md:max-w-md xl:w-64 mx-auto rounded-lg overflow-hidden bg-white shadow-sm hover:shadow-md transition-shadow duration-300">
  <a href={`/books/${slug}`} class="block">
    <div class="flex relative group bg-neutral-50 aspect-square items-center justify-center">
      {currentlyReading && (
        <div class="absolute top-3 right-3 z-10 bg-blue-500 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow-lg">
          In Progress
        </div>
      )}
      <div class="book mx-auto scale-90 sm:scale-100 transition-transform duration-300 group-hover:scale-105">
        <div
          class="book-cover bg-cover bg-center rounded-md"
          style={{ backgroundImage: `url(${cover})` }}
        >
          <div class="effect"></div>
          <div class="light"></div>
        </div>
        <div class="book-inside"></div>
      </div>
    </div>
  </a>

  <div class="p-4 sm:p-5 text-center sm:text-left">
    <h3 class="text-lg sm:text-xl font-light truncate">{title}</h3>
    <p class="text-sm sm:text-base mb-2">{author}</p>
    <div class="flex justify-center sm:justify-start items-center mt-2">
      <div class="flex items-center gap-0.5 text-yellow-400 text-lg">
        <span>★</span>
        <span>★</span>
        <span>★</span>
        <span class="text-neutral-300">☆</span>
        <span class="text-neutral-300">☆</span>
      </div>
    </div>
  </div>
</div>

