---
const { cover, title, author, slug, currentlyReading } = Astro.props;
---

<div class="book-card">
  <a href={`/books/${slug}`} class="block">
    <div class="book-card-cover-wrap">
      {currentlyReading && (
        <div class="book-card-badge">Reading</div>
      )}
      <div class="book mx-auto">
        <div class="book-cover" style={{ backgroundImage: `url(${cover})` }}></div>
        <div class="book-inside" style="background: var(--black-80); border-color: var(--black-70); box-shadow: 10px 40px 40px -10px #00000030, inset -2px 0 0 var(--black-70), inset -3px 0 0 var(--black-80), inset -4px 0 0 var(--black-90), inset -5px 0 0 var(--black-80), inset -6px 0 0 var(--black-90), inset -7px 0 0 var(--black-80), inset -8px 0 0 var(--black-90), inset -9px 0 0 var(--black-80);"></div>
      </div>
    </div>
  </a>
  <div class="book-card-meta">
    <h3 class="book-card-title">{title}</h3>
    <p class="book-card-author">{author}</p>
    <div class="book-card-stars">
      <span class="star star--filled">★</span>
      <span class="star star--filled">★</span>
      <span class="star star--filled">★</span>
      <span class="star">☆</span>
      <span class="star">☆</span>
    </div>
  </div>
</div>

<style>
  .book-card {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .book-card-cover-wrap {
    position: relative;
    background: var(--black-80);
    /* Portrait ratio matches book proportions; padding keeps cover off the edges */
    aspect-ratio: 2 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* Remove the white inset spine highlight — it flashes visibly during 3D rotation */
  .book-cover {
    box-shadow: inset 0 -1px 2px rgba(0,0,0,0.5) !important;
  }

  .book:hover .book-cover {
    box-shadow:
      inset 0 -1px 2px rgba(0,0,0,0.5),
      10px 0px 10px -5px rgba(0,0,0,0.2) !important;
  }

  .book-card-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(59,130,246,0.15);
    color: #60a5fa;
    border: 1px solid rgba(59,130,246,0.3);
    border-radius: 99px;
  }

  .book-card-meta {
    padding: 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .book-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .book-card-author {
    font-size: 0.78rem;
    color: var(--dim);
    font-weight: 300;
  }

  .book-card-stars {
    display: flex;
    justify-content: center;
    gap: 2px;
    font-size: 1rem;
    margin-top: 4px;
  }

  .star { color: var(--border); }
  .star--filled { color: #fbbf24; }
</style>
