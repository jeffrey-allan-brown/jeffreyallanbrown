---
const { heading, subheading, content } = Astro.props;
---
<h2 class="font-mono text-xs/5 font-semibold tracking-widest text-gray-500 uppercase data-dark:text-gray-400">{subheading}</h2>
<h3 class="mt-2 max-w-3xl text-4xl font-medium tracking-tighter text-pretty text-gray-950 data-dark:text-white sm:text-6xl">{heading}</h3>
<p class="font-light mt-8 max-w-xl text-xl/7 text-gray-950/75 sm:text-3xl/8">{content}</p>