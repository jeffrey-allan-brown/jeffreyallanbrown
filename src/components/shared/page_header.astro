---
const { heading, subheading, content } = Astro.props;
---
<div class="page-hdr">
  {subheading && <p class="page-hdr-sub">{subheading}</p>}
  <h1 class="page-hdr-h1">{heading}</h1>
  {content && <p class="page-hdr-desc">{content}</p>}
</div>

<style>
  .page-hdr {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }

  .page-hdr-sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 12px;
  }

  .page-hdr-h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--white);
    margin-bottom: 16px;
  }

  .page-hdr-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--dim);
    max-width: 520px;
  }
</style>
