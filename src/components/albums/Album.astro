---
const { cover, title, artist, color, slug, currentlyListening } = Astro.props;
---

<div class="album-card">
  <a href={`/albums/${slug}`} class="album-card-link">
    <div class="album-card-cover-wrap">
      {currentlyListening && (
        <div class="album-card-badge">Listening</div>
      )}
      <div style={{ '--border-color': color }} class="album-disc">
        <div class="album-arc"></div>
      </div>
      <div
        style={{ backgroundImage: `url(${cover})` }}
        class="album-cover-img"
      ></div>
    </div>
  </a>
  <div class="album-card-meta">
    <h3 class="album-card-title">{title}</h3>
    <p class="album-card-artist">{artist}</p>
    <div class="album-card-stars">
      <span class="star star--filled">★</span>
      <span class="star star--filled">★</span>
      <span class="star star--filled">★</span>
      <span class="star">☆</span>
      <span class="star">☆</span>
    </div>
  </div>
</div>

<style>
  .album-card {
    background: var(--black-90);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .album-card-link {
    display: block;
    text-decoration: none;
  }

  .album-card-cover-wrap {
    position: relative;
    aspect-ratio: 1;
    background: var(--black-80);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .album-card-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(59,130,246,0.15);
    color: #60a5fa;
    border: 1px solid rgba(59,130,246,0.3);
    border-radius: 99px;
  }

  /* Vinyl disc */
  .album-disc {
    position: absolute;
    inset: 0;
    margin: auto;
    width: var(--disk-size, 8rem);
    height: var(--disk-size, 8rem);
    background: #111;
    border-radius: 50%;
    overflow: hidden; /* clips album-arc to the circle */
    z-index: 0;
    animation: album-spin 4s linear infinite;
    /* CSS `translate` is independent of `transform` so rotation keeps spinning on hover */
    transition: translate 0.7s ease-in-out;
  }

  /* Outer groove ring */
  .album-disc::before {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 90%;
    height: 90%;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.18);
  }

  /* Center label dot */
  .album-disc::after {
    content: '';
    position: absolute;
    width: 30%;
    height: 30%;
    border-radius: 50%;
    border: 8px solid var(--border-color, #888);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  /* Top-right white arc — clipped to circle by parent overflow:hidden */
  .album-arc {
    position: absolute;
    width: 50%;
    height: 50%;
    top: 0;
    left: 50%;
    background: rgba(255,255,255,0.15);
    filter: blur(3px);
  }

  .album-cover-img {
    position: relative;
    z-index: 1;
    width: 150px;
    height: 150px;
    background-size: cover;
    background-position: center;
    background-color: var(--black-70);
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    transition: translate 0.7s ease-in-out;
  }

  /* Slide disc right, cover left on hover */
  .album-card-cover-wrap:hover .album-disc {
    translate: 2.5rem 0;
  }

  .album-card-cover-wrap:hover .album-cover-img {
    translate: -1.75rem 0;
  }

  @keyframes album-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .album-card-meta {
    padding: 14px 16px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .album-card-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .album-card-artist {
    font-size: 0.75rem;
    color: var(--dim);
    font-weight: 300;
  }

  .album-card-stars {
    display: flex;
    justify-content: center;
    gap: 2px;
    font-size: 0.95rem;
    margin-top: 4px;
  }

  .star { color: var(--border); }
  .star--filled { color: #fbbf24; }
</style>
