---
const { title, date, excerpt, slug, tags = [], maturity } = Astro.props;

const maturityConfig = {
  seedling: { emoji: "🌱" },
  budding:  { emoji: "🌿" },
  evergreen:{ emoji: "🌲" },
};
const maturityData = maturityConfig[maturity as keyof typeof maturityConfig];
---

<article class="note-container">
  <a href={`/garden/${slug}`} class="note-paper">
    <div class="note-content">
      <div class="note-header">
        <h3 class="note-title">{title}</h3>
        <div class="note-meta">
          {maturityData && <span class="note-maturity">{maturityData.emoji}</span>}
          {date && <span class="note-date">{date}</span>}
        </div>
      </div>

      {excerpt && <p class="note-excerpt">{excerpt}</p>}

      {tags.length > 0 && (
        <div class="note-tags">
          {tags.map((tag: string) => (
            <span class="note-tag">#{tag}</span>
          ))}
        </div>
      )}

      <span class="note-read-more">→ READ MORE</span>
    </div>

    <div class="dot-matrix-overlay" aria-hidden="true"></div>
  </a>
</article>

<style>
  .note-container {
    transition: transform 0.18s ease;
  }

  .note-container:hover {
    transform: translateY(-2px);
  }

  .note-paper {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    color: var(--note-text);
    background-color: var(--note-paper);
    background-image: radial-gradient(circle, rgba(78,87,106,0.2) 1px, transparent 1px);
    background-size: 14px 14px;
    border: 1px solid var(--note-border);
    border-radius: 2px;
    box-shadow: 2px 3px 10px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.15);
    min-height: 180px;
  }

  .note-container:hover .note-paper {
    box-shadow: 3px 6px 16px rgba(0,0,0,0.35), 0 2px 4px rgba(0,0,0,0.2);
  }

  /* Feed strip */
  .note-paper::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 26px;
    background-color: var(--note-feed);
    background-image: radial-gradient(circle, var(--note-sprocket) 4px, transparent 4.5px);
    background-size: 26px 28px;
    background-repeat: repeat-y;
    background-position: center 8px;
  }

  /* Margin line */
  .note-paper::after {
    content: '';
    position: absolute;
    left: 26px; top: 0; bottom: 0;
    width: 1.5px;
    background: rgba(208,58,58,0.4);
  }

  .note-content {
    position: relative;
    z-index: 1;
    padding: 18px 18px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .note-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .note-title {
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--note-text);
    line-height: 1.35;
    letter-spacing: -0.01em;
    flex: 1;
  }

  .note-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }

  .note-maturity {
    font-size: 1rem;
    line-height: 1;
  }

  .note-date {
    font-size: 0.62rem;
    font-family: monospace;
    color: var(--note-dimmer);
    opacity: 0.75;
    white-space: nowrap;
  }

  .note-excerpt {
    font-family: monospace;
    font-size: 0.78rem;
    color: var(--note-excerpt);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .note-tag {
    font-family: monospace;
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--note-tag);
    border: 1px solid var(--note-border);
    padding: 1px 6px;
    border-radius: 2px;
  }

  .note-read-more {
    font-family: monospace;
    font-size: 0.65rem;
    color: var(--note-dimmer);
    margin-top: 2px;
  }

  .dot-matrix-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1px, transparent 1px);
    background-size: 4px 4px;
    opacity: 0.4;
  }
</style>
