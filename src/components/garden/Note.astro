---
const { title, date, excerpt, slug, tags = [], maturity } = Astro.props;

const maturityConfig = {
  seedling: { emoji: "🌱" },
  budding:  { emoji: "🌿" },
  evergreen:{ emoji: "🌲" },
};
const maturityData = maturityConfig[maturity as keyof typeof maturityConfig];
---

<a href={`/garden/${slug}`} class="note-card">
  <div class="note-maturity-row">
    {maturityData && <span class="note-maturity">{maturityData.emoji}</span>}
    {date && <span class="note-date">{date}</span>}
  </div>

  <div class="note-title">{title}</div>

  {excerpt && <div class="note-excerpt">{excerpt}</div>}

  {tags.length > 0 && (
    <div class="note-tags">
      {tags.map((tag: string) => (
        <span class="note-tag">#{tag}</span>
      ))}
    </div>
  )}

  <span class="note-read-more">→ READ MORE</span>
</a>

<style>
  .note-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 16px 18px 38px;
    border: none;
    border-radius: 2px;
    text-decoration: none;
    color: #0A0E15;
    overflow: hidden;

    background-color: #E0E4EB;
    background-image: radial-gradient(circle, rgba(78, 87, 106, 0.12) 1px, transparent 1px);
    background-size: 14px 14px;

    box-shadow: 2px 3px 10px rgba(0, 0, 0, 0.5), 0 1px 2px rgba(0, 0, 0, 0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  /* Feed strip with sprocket holes */
  .note-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 26px;
    background-color: #D1D6E0;
    background-image: radial-gradient(circle, #4E576A 4px, transparent 4.5px);
    background-size: 26px 28px;
    background-repeat: repeat-y;
    background-position: center 8px;
  }

  /* Red margin line */
  .note-card::after {
    content: '';
    position: absolute;
    left: 26px; top: 0; bottom: 0;
    width: 1.5px;
    background: rgba(208, 58, 58, 0.5);
  }

  .note-card:hover {
    transform: translateY(-2px);
    box-shadow: 3px 6px 16px rgba(0, 0, 0, 0.55), 0 2px 4px rgba(0, 0, 0, 0.25);
  }

  .note-maturity-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .note-maturity {
    font-size: 0.9rem;
    line-height: 1;
  }

  .note-date {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: #667085;
  }

  .note-title {
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #0A0E15;
  }

  .note-excerpt {
    font-size: 0.77rem;
    font-weight: 400;
    line-height: 1.6;
    color: #373F4E;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }

  .note-tag {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #4E576A;
    border: 1px solid rgba(78, 87, 106, 0.35);
    padding: 2px 7px;
    border-radius: 2px;
  }

  .note-read-more {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #667085;
    margin-top: 2px;
  }

  /* Light mode */
  html[data-theme="light"] .note-card {
    background-color: #FFFFFF;
    background-image: radial-gradient(circle, rgba(78, 87, 106, 0.16) 1px, transparent 1px);
    box-shadow: 2px 3px 8px rgba(0, 0, 0, 0.10), 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  html[data-theme="light"] .note-card::before {
    background-color: #F0F1F5;
    background-image: radial-gradient(circle, #BFC6D4 4px, transparent 4.5px);
  }

  html[data-theme="light"] .note-card:hover {
    box-shadow: 3px 5px 14px rgba(0, 0, 0, 0.14), 0 2px 4px rgba(0, 0, 0, 0.08);
  }
</style>
